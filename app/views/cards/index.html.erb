<section class="app-page">
  <div class="app-page__hero">
    <div class="app-page__hero-top app-page__hero-top--cards">
      <div class="app-page__hero-unit app-page__hero-copy">
        <span class="app-page__hero-icon">
          <span class="material-symbols-rounded">credit_card</span>
        </span>
        <div>
          <p class="app-page__eyebrow">Gestão</p>
          <h1 class="app-page__title">Cartões</h1>
          <%# <p class="app-page__description">Acompanhe limites, vencimentos e acione rapidamente o fechamento do mês.</p> %>
        </div>
      </div>

      <div class="app-page__hero-kpis">
        <%= render "hero_kpis" %>
      </div>

      <div class="app-page__hero-unit">
        <%= render "shared/app_page_hero_badge" %>
      </div>
    </div>
  </div>

  <div class="app-panel app-panel--table">
    <div class="table-responsive">
      <table class="table app-table app-table--records app-table--index mb-0">
        <thead>
          <tr>
            <th><%= t("cards.form.name") %></th>
            <th><%= t("cards.form.number") %></th>
            <th>Limite Total</th>
            <th>Limite Restante</th>
            <th>Dia do Vencimento</th>
            <th>Melhor Dia de Compra</th>
            <th><%= t("tables.expenses.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @cards.each do |card| %>
            <tr id="<%= dom_id(card) %>">
              <td>
                <%= card.icon.attached? ? image_tag(card.icon, width: 20, class: "me-2") : "💳" %>
                <%= card.name %>
              </td>
              <td><%= card.number.present? ? "**** **** **** #{card.number[-4..-1]}" : "" %></td>
              <td><%= number_to_currency(card.total_limit || 0, unit: "R$ ", separator: ",", delimiter: ".") %></td>
              <td><%= number_to_currency(card.remaining_limit || 0, unit: "R$ ", separator: ",", delimiter: ".") %></td>
              <td><%= card.due_day %></td>
              <td><%= card.best_day %></td>
              <td class="app-record-actions">
                <%= link_to t("buttons.edit"),
                    edit_card_path(card),
                    class: "btn btn-sm btn-primary app-record-actions__edit me-1",
                    data: { turbo_frame: "modal" } %>
                <%= link_to t("buttons.delete"), card,
                            data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                            class: "btn btn-sm btn-danger app-record-actions__delete me-1" %>
                <%= form_with url: pay_card_path(card), method: :post, data: { turbo_confirm: "Deseja marcar como pagas todas as despesas e parcelas NÃO pagas deste cartão para o mês atual?" }, class: "d-inline" do %>
                  <%= submit_tag "Pagar", class: "btn btn-sm btn-warning app-record-actions__pay" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Frame vazio para renderização dinâmica -->
<turbo-frame id="modal" style="display: none;"></turbo-frame>

<!-- Estrutura do modal principal -->
<div class="modal fade" id="turboModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div id="modal-body" style="height: 460px;"></div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function () {
    document.querySelectorAll(".pay-card-btn").forEach(function (btn) {
      btn.addEventListener("click", function (e) {
        const cardId = e.currentTarget.dataset.cardId;
        if (!cardId) return;

        const confirmation = confirm("Deseja marcar como pagas todas as despesas e parcelas NÃO pagas deste cartão para o mês atual?");
        if (!confirmation) return;

        const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

        fetch(`/cards/${cardId}/pay`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": token,
            "Accept": "text/html"
          },
          body: JSON.stringify({})
        })
        .then(response => {
          if (response.redirected) {
            window.location.href = response.url;
          } else {
            window.location.reload();
          }
        })
        .catch(err => {
          console.error(err);
          alert("Ocorreu um erro ao tentar pagar. Veja o console para mais detalhes.");
        });
      });
    });
  });
</script>
