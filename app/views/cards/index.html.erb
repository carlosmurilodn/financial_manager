<section class="app-page">
  <div class="app-page__hero">
    <div class="app-page__hero-top app-page__hero-top--cards">
      <div class="app-page__hero-unit app-page__hero-copy">
        <span class="app-page__hero-icon">
          <span class="material-symbols-rounded">credit_card</span>
        </span>
        <div>
          <p class="app-page__eyebrow">Gestão</p>
          <h1 class="app-page__title">Cartões</h1>
          <%# <p class="app-page__description">Acompanhe limites, vencimentos e acione rapidamente o fechamento do mês.</p> %>
        </div>
      </div>

      <div class="app-page__hero-kpis">
        <%= render "hero_kpis" %>
      </div>

      <div class="app-page__hero-unit">
        <%= render "shared/app_page_hero_badge" %>
      </div>
    </div>
  </div>

  <div class="app-panel">
    <%= form_with url: cards_path, method: :get, local: true, class: "app-filter-form" do |f| %>
      <div class="app-filter-grid app-filter-grid--cards">
        <div class="app-filter-field">
          <%= f.label :description, "Descrição" %>
          <%= f.text_field :description, value: @description_filter, class: "form-control", placeholder: "Buscar dívida ou cartão..." %>
        </div>

        <div class="app-filter-field">
          <%= f.label :month, "Mês" %>
          <%= f.select :month,
                options_for_select(
                  [["Todos", 0]] + I18n.t("date.month_names")[1..12].map.with_index { |m, i| [m.capitalize, i + 1] },
                  @month || 0
                ),
                {}, class: "form-select" %>
        </div>

        <div class="app-filter-field">
          <%= f.label :year, "Ano" %>
          <%= f.select :year,
                options_for_select([["Todos", 0]] + (@card_debt_years || []), @year || 0),
                {}, class: "form-select" %>
        </div>
      </div>

      <div class="app-filter-actions">
        <%= f.button class: "btn app-page__primary-btn" do %>
          <i class="bi bi-funnel me-1"></i> <%= t("buttons.filter") %>
        <% end %>

        <%= link_to clear_filters_cards_path,
                    class: "btn app-page__secondary-btn",
                    data: { turbo_method: :delete } do %>
          <i class="bi bi-x-circle me-1"></i> Limpar Filtros
        <% end %>

        <%= render "shared/per_page_select" %>
      </div>
    <% end %>
  </div>

  <div class="app-panel app-panel--table">
    <div class="table-responsive">
      <table class="table app-table app-table--records app-table--index mb-0">
        <thead>
          <tr>
            <th><%= sortable_table_header(t("cards.form.name"), "name") %></th>
            <th><%= sortable_table_header(t("cards.form.number"), "number") %></th>
            <th><%= sortable_table_header("Limite Total", "total_limit") %></th>
            <th><%= sortable_table_header("Limite Restante", "remaining_limit") %></th>
            <th><%= sortable_table_header("Valor do Mês de Balanço", "balance_month_amount") %></th>
            <th><%= sortable_table_header("Dia do Vencimento", "due_day") %></th>
            <th><%= sortable_table_header("Dia de Fechamento", "closing_day") %></th>
            <th><%= t("tables.expenses.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @cards.each do |card| %>
            <tr id="<%= dom_id(card) %>">
              <td>
                <%= card.icon.attached? ? image_tag(card.icon, width: 20, class: "me-2") : "💳" %>
                <%= card.name %>
              </td>
              <td class="text-center"><%= card.number.present? ? "**** **** **** #{card.number[-4..-1]}" : "" %></td>
              <td class="text-center"><%= number_to_currency(card.total_limit || 0, unit: "R$ ", separator: ",", delimiter: ".") %></td>
              <td class="text-center"><%= number_to_currency(card.total_limit.to_f - @card_debt_totals_by_card.fetch(card.id, 0).to_f, unit: "R$ ", separator: ",", delimiter: ".") %></td>
              <td class="text-center"><%= number_to_currency(@card_debt_totals_by_card.fetch(card.id, 0), unit: "R$ ", separator: ",", delimiter: ".") %></td>
              <td class="text-center"><%= card.due_day %></td>
              <td class="text-center"><%= card.closing_day %></td>
              <td class="app-record-actions text-center">
                <%= link_to "✏️ #{t("buttons.edit")}",
                    edit_card_path(card),
                    class: "btn btn-sm btn-primary app-record-actions__edit me-1",
                    data: { turbo_frame: "modal" } %>
                <%= link_to "🗑️ #{t("buttons.delete")}", card,
                            data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                            class: "btn btn-sm btn-danger app-record-actions__delete me-1" %>
                <%= form_with url: pay_card_path(card), method: :post, data: { turbo_confirm: "Deseja marcar como pagas todas as despesas e parcelas NÃO pagas deste cartão para o mês de balanço #{@pay_balance_month_label}?" }, class: "d-inline" do %>
                  <%= hidden_field_tag :month, @month if @month.present? %>
                  <%= hidden_field_tag :year, @year if @year.present? %>
                  <%= submit_tag "💳 Pagar", class: "btn btn-sm btn-warning app-record-actions__pay" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= render "shared/pagination",
              current_page: @current_page,
              total_pages: @total_pages,
              base_params: request.query_parameters.except(:page),
              aria_label: "Paginacao de cartoes" %>
  </div>
</section>

<!-- Frame vazio para renderização dinâmica -->
<turbo-frame id="modal" style="display: none;"></turbo-frame>

<!-- Estrutura do modal principal -->
<div class="modal fade" id="turboModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div id="modal-body"></div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function () {
    document.querySelectorAll(".pay-card-btn").forEach(function (btn) {
      btn.addEventListener("click", function (e) {
        const cardId = e.currentTarget.dataset.cardId;
        if (!cardId) return;

        const confirmation = confirm("Deseja marcar como pagas todas as despesas e parcelas NÃO pagas deste cartão para o mês atual?");
        if (!confirmation) return;

        const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

        fetch(`/cards/${cardId}/pay`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": token,
            "Accept": "text/html"
          },
          body: JSON.stringify({})
        })
        .then(response => {
          if (response.redirected) {
            window.location.href = response.url;
          } else {
            window.location.reload();
          }
        })
        .catch(err => {
          console.error(err);
          alert("Ocorreu um erro ao tentar pagar. Veja o console para mais detalhes.");
        });
      });
    });
  });
</script>
