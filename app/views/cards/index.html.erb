<div class="container py-4">
  <h1 class="mb-4"><%= t("tables.cards.title", default: "Cartões") %></h1>

  <%= link_to t("buttons.new.masculine", model: t("models.card")), new_card_path, class: "btn btn-success mb-3" %>

  <table class="table table-striped">
    <thead>
      <tr>
        <th><%= t("cards.form.name") %></th>
        <th><%= t("cards.form.number") %></th>
        <th>Limite Total</th>
        <th>Limite Restante</th>
        <th>Dia do Vencimento</th>
        <th>Melhor Dia de Compra</th>
        <th><%= t("tables.expenses.actions") %></th>
      </tr>
    </thead>
    <tbody>
      <% @cards.each do |card| %>
        <tr id="<%= dom_id(card) %>">
          <td><%= card.name %></td>
          <td><%= card.number.present? ? "**** **** **** #{card.number[-4..-1]}" : "" %></td>
          <td><%= number_to_currency(card.total_limit || 0) %></td>
          <td><%= number_to_currency(card.remaining_limit || 0) %></td>
          <td><%= card.due_day %></td>
          <td><%= card.best_day %></td>
          <td>
            <%= link_to t("buttons.edit"), edit_card_path(card), class: "btn btn-sm btn-primary" %>
            <%= link_to t("buttons.delete"), card,
                        data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                        class: "btn btn-sm btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
