<div id="categories-hero-kpis" class="app-categories-hero-kpis">
  <div class="app-page__hero-unit">
    <%= link_to new_category_path,
                class: "app-expenses-hero-kpis__action",
                data: { turbo_frame: "modal" } do %>
      <span class="app-expenses-hero-kpis__action-icon">
        <span class="material-symbols-rounded">add</span>
      </span>
      <span class="app-expenses-hero-kpis__action-copy">
        <strong><%= t("buttons.new.feminine", model: t("models.category")) %></strong>
      </span>
    <% end %>
  </div>

  <div class="app-page__hero-unit">
    <div class="stat-card stat-card--danger">
      <div class="stat-card__icon">
        <span class="material-symbols-rounded">payments</span>
      </div>
      <div>
        <span class="stat-card__label">Despesas do Mês</span>
        <strong class="stat-card__value">
          <%= number_to_currency(@categories_month_expenses || 0, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
        </strong>
      </div>
    </div>
  </div>

  <div class="app-page__hero-unit">
    <div class="stat-card stat-card--success">
      <div class="stat-card__icon">
        <span class="material-symbols-rounded">trending_up</span>
      </div>
      <div>
        <span class="stat-card__label">Receitas do Mês</span>
        <strong class="stat-card__value">
          <%= number_to_currency(@categories_month_incomes || 0, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
        </strong>
      </div>
    </div>
  </div>

  <div class="app-page__hero-unit">
    <div class="stat-card stat-card--warning">
      <div class="stat-card__icon">
        <span class="material-symbols-rounded">leaderboard</span>
      </div>
      <div>
        <span class="stat-card__label">Maior Categoria</span>
        <strong class="stat-card__value">
          <%= number_to_currency(@categories_top_expense_value || 0, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
        </strong>
      </div>
    </div>
  </div>

  <div class="app-page__hero-unit">
    <div class="stat-card stat-card--primary">
      <div class="stat-card__icon">
        <span class="material-symbols-rounded">category_search</span>
      </div>
      <div>
        <span class="stat-card__label">Sem Categoria</span>
        <strong class="stat-card__value">
          <%= number_to_currency(@categories_uncategorized_value || 0, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
        </strong>
      </div>
    </div>
  </div>
</div>
