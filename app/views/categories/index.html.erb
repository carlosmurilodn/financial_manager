<section class="app-page">
  <div class="app-page__hero">
    <div class="app-page__hero-top app-page__hero-top--categories">
      <div class="app-page__hero-unit app-page__hero-copy">
        <span class="app-page__hero-icon">
          <span class="material-symbols-rounded">category</span>
        </span>
        <div>
          <p class="app-page__eyebrow">Gestão</p>
          <h1 class="app-page__title">Categorias</h1>
          <%# <p class="app-page__description">Centralize a organização visual das suas receitas e despesas por categoria.</p> %>
        </div>
      </div>

      <div class="app-page__hero-kpis">
        <%= render "hero_kpis" %>
      </div>

      <div class="app-page__hero-unit">
        <%= render "shared/app_page_hero_badge" %>
      </div>
    </div>
  </div>

  <div class="app-panel app-panel--table">
    <div class="app-list-toolbar">
      <%= form_with url: categories_path, method: :get, local: true, class: "app-list-toolbar__form" do %>
        <div class="app-filter-field app-list-toolbar__search">
          <%= label_tag :description, "Descricao" %>
          <%= text_field_tag :description, @description_filter, class: "form-control", placeholder: "Buscar descricao..." %>
        </div>

        <%= button_tag class: "btn app-page__primary-btn app-list-toolbar__button" do %>
          <i class="bi bi-funnel me-1"></i> <%= t("buttons.filter") %>
        <% end %>

        <% if @description_filter.present? %>
          <%= link_to categories_path(request.query_parameters.except(:description, :page)), class: "btn app-page__secondary-btn app-list-toolbar__button" do %>
            <i class="bi bi-x-circle me-1"></i> Limpar
          <% end %>
        <% end %>

        <%= render "shared/per_page_select" %>
      <% end %>
    </div>

    <div class="table-responsive">
      <table class="table app-table app-table--records app-table--index mb-0">
        <thead>
          <tr>
            <th><%= sortable_table_header("Ícone", "icon") %></th>
            <th><%= sortable_table_header(t("categories.form.name"), "name") %></th>
            <th><%= t("tables.expenses.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @categories.each do |category| %>
            <tr id="<%= dom_id(category) %>">
              <td>
                <span class="material-symbols-rounded dashboard-category-item__icon"><%= category.material_icon %></span>
              </td>
              <td><%= category.display_name %></td>
              <td class="app-record-actions text-center">
                <%= link_to t("buttons.edit"), edit_category_path(category), class: "btn btn-sm btn-primary app-record-actions__edit", data: { turbo_frame: "modal" } %>
                <%= link_to t("buttons.delete"), category,
                            data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                            class: "btn btn-sm btn-danger app-record-actions__delete" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= render "shared/pagination",
              current_page: @current_page,
              total_pages: @total_pages,
              base_params: request.query_parameters.except(:page),
              aria_label: "Paginacao de categorias" %>
  </div>
</section>

<!-- Frame vazio para renderização dinâmica -->
<turbo-frame id="modal" style="display: none;"></turbo-frame>

<!-- Estrutura do modal principal -->
<div class="modal fade" id="turboModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div id="modal-body"></div>
    </div>
  </div>
</div>
