<section class="app-page">
  <div class="app-page__hero">
    <div class="app-page__hero-copy">
      <span class="app-page__hero-icon">
        <%= image_tag "icons/category.png", alt: "Categorias", size: "22x22" %>
      </span>
      <div>
        <p class="app-page__eyebrow">Gestão</p>
        <h1 class="app-page__title">Categorias</h1>
        <p class="app-page__description">Centralize a organização visual das suas receitas e despesas por categoria.</p>
      </div>
    </div>

    <div class="app-page__hero-actions">
      <%= link_to t("buttons.new.feminine", model: t("models.category")),
      new_category_path,
      class: "btn app-page__primary-btn",
      data: { turbo_frame: "modal" } %>
    </div>
  </div>

  <div class="app-panel app-panel--table">
    <div class="table-responsive">
      <table class="table app-table app-table--records app-table--index mb-0">
        <thead>
          <tr>
            <th><%= t("categories.form.name") %></th>
            <th><%= t("tables.expenses.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @categories.each do |category| %>
            <tr id="<%= dom_id(category) %>">
              <td><%= category.display_name %></td>
              <td class="app-record-actions">
                <%= link_to t("buttons.edit"), edit_category_path(category), class: "btn btn-sm btn-primary", data: { turbo_frame: "modal" } %>
                <%= link_to t("buttons.delete"), category,
                            data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                            class: "btn btn-sm btn-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Frame vazio para renderização dinâmica -->
<turbo-frame id="modal" style="display: none;"></turbo-frame>

<!-- Estrutura do modal principal -->
<div class="modal fade" id="turboModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div id="modal-body" style="height: 280px;"></div>
    </div>
  </div>
</div>
