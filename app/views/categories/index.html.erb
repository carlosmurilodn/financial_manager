<section class="app-page">
  <div class="app-page__hero">
    <div class="app-page__hero-top app-page__hero-top--categories">
      <div class="app-page__hero-unit app-page__hero-copy">
        <span class="app-page__hero-icon">
          <span class="material-symbols-rounded">category</span>
        </span>

        <div>
          <p class="app-page__eyebrow">Gestão</p>
          <h1 class="app-page__title">Categorias</h1>
          <%# <p class="app-page__description">Centralize a organização visual das suas receitas e despesas por categoria.</p> %>
        </div>
      </div>

      <div class="app-page__hero-kpis">
        <%= render "hero_kpis" %>
      </div>

      <div class="app-page__hero-unit">
        <%= render "shared/app_page_hero_badge" %>
      </div>
    </div>
  </div>

  <div class="app-panel">
    <%= form_with url: categories_path, method: :get, local: true, class: "app-filter-form" do |f| %>
      <div class="app-filter-grid">
        <div class="app-filter-field">
          <%= f.label :description, "Descrição" %>
          <%= f.text_field :description,
                value: @description_filter,
                class: "app-form-control",
                placeholder: "Buscar descrição..." %>
        </div>
      </div>

      <div class="app-filter-actions">
        <%= f.button class: "app-btn app-btn--primary app-page__primary-btn" do %>
          <i class="bi bi-funnel app-me-1"></i> <%= t("buttons.filter") %>
        <% end %>

        <%= link_to categories_path,
                    class: "app-btn app-btn--secondary app-page__secondary-btn" do %>
          <i class="bi bi-x-circle app-me-1"></i> Limpar Filtros
        <% end %>

        <%= render "shared/per_page_select" %>
      </div>
    <% end %>
  </div>

  <div class="app-panel app-panel--table">
    <div class="app-table-responsive">
      <table class="app-table app-table--records app-table--index app-mb-0">
        <thead>
          <tr>
            <th class="app-text-center">Item</th>
            <th><%= sortable_table_header("Ícone", "icon") %></th>
            <th><%= sortable_table_header(t("categories.form.name"), "name") %></th>
            <th><%= t("tables.expenses.actions") %></th>
          </tr>
        </thead>

        <tbody>
          <% @categories.each_with_index do |category, index| %>
            <tr id="<%= dom_id(category) %>">
              <td class="app-text-center app-record-actions">
                <%= @item_offset + index + 1 %>
              </td>

              <td>
                <span class="material-symbols-rounded dashboard-category-item__icon">
                  <%= category.material_icon %>
                </span>
              </td>

              <td><%= category.display_name %></td>

              <td class="app-record-actions app-text-center">
                <%= link_to "✏️ #{t("buttons.edit")}",
                            edit_category_path(category),
                            class: "app-btn app-btn--sm app-btn--primary app-record-actions__edit app-me-1",
                            data: { turbo_frame: "modal" } %>

                <%= link_to "🗑️ #{t("buttons.delete")}",
                            category,
                            data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                            class: "app-btn app-btn--sm app-btn--danger app-record-actions__delete" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= render "shared/pagination",
              current_page: @current_page,
              total_pages: @total_pages,
              base_params: request.query_parameters.except(:page),
              aria_label: "Paginação de categorias" %>
  </div>
</section>

<turbo-frame id="modal" style="display: none;"></turbo-frame>

<div id="appModal" class="app-modal" aria-hidden="true">
  <div class="app-modal__backdrop" data-modal-backdrop="true"></div>

  <div class="app-modal__dialog">
    <div class="app-modal__content">
      <div id="app-modal-body"></div>
    </div>
  </div>
</div>