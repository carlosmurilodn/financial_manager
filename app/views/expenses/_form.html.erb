<% categories = Category.order(:name) %>
<% cards = Card.all %>
<% payment_options = Expense.payment_method_names.map { |key, label| [label, key] } %>

<% if expense.persisted? %>
  <%= form_with model: expense, local: false, html: { id: "expense_form" } do |f| %>
    <div class="expense-modal-grid expense-modal-grid--edit">
      <div class="expense-modal-field expense-modal-field--wide">
        <%= f.label :description, t("expenses.form.description") %>
        <%= f.text_field :description, class: "app-form-control", required: true %>
      </div>

      <div class="expense-modal-field">
        <%= f.label :repetir, "Repetir (meses)" %>
        <%= f.number_field :repetir, value: @expense.repetir || 0, min: 0, class: "app-form-control" %>
      </div>

      <div class="expense-modal-field">
        <%= f.label :amount, t("expenses.form.amount") %>
        <%= f.text_field :amount,
          class: "app-form-control moeda",
          value: (expense.amount.present? ? number_to_currency(expense.amount, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) : "R$ 0,00"),
          required: true,
          data: { required_currency: true }
        %>
      </div>

      <div class="expense-modal-field expense-modal-field--check app-form-check">
        <%= f.check_box :paid, class: "app-form-check-input", id: "expense_paid" %>
        <%= f.label :paid, t("expenses.form.paid"), class: "app-form-check-label" %>
      </div>

      <div class="expense-modal-field">
        <%= f.label :date, t("expenses.form.date") %>
        <div class="custom-date-wrapper">
          <%= f.text_field :date, class: "app-form-control custom-date", autocomplete: "off", placeholder: "Selecione a data", required: true %>
        </div>
      </div>

      <div class="expense-modal-field">
        <%= f.label :balance_month, t("expenses.form.balance_month") %>
        <div class="custom-date-wrapper">
          <%= f.text_field :balance_month, class: "app-form-control custom-date", autocomplete: "off", placeholder: "Selecione o mês", required: true %>
        </div>
      </div>

      <div class="expense-modal-field">
        <%= f.label :category_id, t("expenses.form.category") %>
        <%= f.collection_select :category_id, categories, :id, :display_name, { prompt: "Selecione" }, { class: "app-form-select", required: true } %>
      </div>

      <div class="expense-modal-field">
        <%= f.label :payment_method, t("expenses.form.payment_method") %>
        <%= f.select :payment_method, payment_options,
          { prompt: "Selecione" },
          { class: "app-form-select", id: "payment_method_select", required: true } %>
      </div>

      <div class="expense-modal-field">
        <%= f.label :card_id, t("expenses.form.card") %>
        <%= f.collection_select :card_id, cards, :id, :display_name, { prompt: "Selecione" }, { class: "app-form-select", data: { required_when_credit: true } } %>
      </div>
    </div>

    <div class="expense-modal-installments" id="parcelamento_section">
      <div class="expense-modal-field">
        <%= f.label :current_installment, "Parcela Atual" %>
        <%= f.number_field :current_installment, class: "app-form-control", value: expense.current_installment || 1, min: 1, data: { required_when_installments: true } %>
      </div>

      <div class="expense-modal-field">
        <%= f.label :installments_count, "Total de Parcelas" %>
        <%= f.number_field :installments_count, class: "app-form-control", value: expense.installments_count || 1, min: 1, data: { required_when_installments: true } %>
      </div>
    </div>

    <% if expense.payment_method_credito_parcelado? %>
      <div class="alert alert-info" role="alert">
        Escolha abaixo se deseja atualizar apenas esta parcela ou aplicar as alterações desta parcela em diante.
      </div>
    <% end %>

    <div class="expense-modal-actions">
      <% if expense.payment_method_credito_parcelado? %>
        <%= button_tag name: "update_scope", value: "single", type: "submit", class: "app-btn app-btn--primary expense-modal-action-btn" do %>
          <span class="material-symbols-rounded">save</span>
          Atualizar só esta parcela
        <% end %>

        <%= button_tag name: "update_scope", value: "group", type: "submit", class: "app-btn app-btn--outline expense-modal-action-btn" do %>
          <span class="material-symbols-rounded">done_all</span>
          Atualizar esta e próximas
        <% end %>
      <% else %>
        <%= button_tag type: "submit", class: "app-btn app-btn--primary expense-modal-action-btn" do %>
          <span class="material-symbols-rounded">save</span>
          <%= t("expenses.form.submit") %>
        <% end %>
      <% end %>
    </div>
  <% end %>
<% else %>
  <%= form_with url: expenses_path, local: false, html: { id: "expense_form", data: { expense_form: true } } do %>
    <div class="expense-modal-rows" data-expense-rows>
      <%= render "expenses/form_row",
        index: 0,
        categories: categories,
        cards: cards,
        payment_options: payment_options,
        removable: false %>
    </div>

    <template data-expense-row-template>
      <%= render "expenses/form_row",
        index: "NEW_RECORD",
        categories: categories,
        cards: cards,
        payment_options: payment_options,
        removable: true %>
    </template>

    <div class="expense-modal-actions">
      <button type="button" class="app-btn app-btn--primary expense-modal-action-btn" data-add-expense-row>
        <span class="material-symbols-rounded">add_circle</span>
        Inserir Despesa
      </button>

      <button type="submit" class="app-btn app-btn--primary expense-modal-action-btn">
        <span class="material-symbols-rounded">save</span>
        <%= t("expenses.form.submit") %>
      </button>
    </div>
  <% end %>
<% end %>
