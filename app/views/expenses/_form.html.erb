<%= form_with model: expense, local: false, html: { id: "expense_form" } do |f| %>
  <div class="row mb-3">
    <div class="col-md-9">
      <%= f.label :description, t("expenses.form.description") %>
      <%= f.text_field :description, class: "form-control" %>
    </div>
    <div class="col-md-3">
      <%= f.label :repetir, "Repetir (meses)" %>
      <%= f.number_field :repetir, value: @expense.repetir || 0, min: 0, class: "form-control" %>
    </div>
  </div>

  <div class="row mb-3 align-items-end">
    <div class="col-md-4">
      <%= f.label :amount, t("expenses.form.amount") %>
      <div class="d-flex align-items-center gap-2">
        <%= f.text_field :amount, 
          class: "form-control moeda flex-grow-1", 
          value: (expense.amount.present? ? number_to_currency(expense.amount, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) : "R$ 0,00")
        %>
        <div class="form-check mb-0">
          <%= f.check_box :paid, class: "form-check-input", id: "expense_paid" %>
          <%= f.label :paid, t("expenses.form.paid"), class: "form-check-label ms-1" %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <%= f.label :date, t("expenses.form.date") %>
      <div class="custom-date-wrapper">
        <%= f.text_field :date, class: "form-control custom-date", autocomplete: "off", placeholder: "Selecione a data" %>
      </div>
    </div>

    <div class="col-md-4">
      <%= f.label :balance_month, t("expenses.form.balance_month") %>
      <div class="custom-date-wrapper">
        <%= f.text_field :balance_month, class: "form-control custom-date", autocomplete: "off", placeholder: "Selecione o mês" %>
      </div>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <%= f.label :category_id, t("expenses.form.category") %>
      <%= f.collection_select :category_id, Category.order(:name), :id, :display_name, { prompt: "Selecione" }, { class: "form-select" } %>
    </div>

    <div class="col-md-4">
      <%= f.label :payment_method, t("expenses.form.payment_method") %>
      <%= f.select :payment_method, Expense.payment_method_names.map { |k,v| [v,k] },
        { prompt: "Selecione" },
        { class: "form-select", id: "payment_method_select" } %>
    </div>

    <div class="col-md-4">
      <%= f.label :card_id, t("expenses.form.card") %>
      <%= f.collection_select :card_id, Card.all, :id, :display_name, { prompt: "Selecione" }, { class: "form-select" } %>
    </div>
  </div>

  <div class="row mb-3" id="parcelamento_section">
    <div class="col-md-6">
      <%= f.label :current_installment, "Parcela Atual" %>
      <%= f.number_field :current_installment, class: "form-control", value: expense.current_installment || 1, min: 1 %>
    </div>

    <div class="col-md-6">
      <%= f.label :installments_count, "Total de Parcelas" %>
      <%= f.number_field :installments_count, class: "form-control", value: expense.installments_count || 1, min: 1 %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.submit t("expenses.form.submit"), class: "btn btn-primary" %>
  </div>
<% end %>
