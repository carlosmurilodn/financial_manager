<div class="expense-modal-row" data-expense-row>
  <div class="expense-modal-row__main">
    <div class="expense-modal-field expense-modal-field--description">
      <label for="expenses_<%= index %>_description"><%= t("expenses.form.description") %></label>
      <input type="text" name="expenses[<%= index %>][description]" id="expenses_<%= index %>_description" class="form-control">
    </div>

    <div class="expense-modal-field expense-modal-field--repeat">
      <label for="expenses_<%= index %>_repetir">Repetir</label>
      <input type="number" name="expenses[<%= index %>][repetir]" id="expenses_<%= index %>_repetir" value="0" min="0" class="form-control">
    </div>

    <div class="expense-modal-field expense-modal-field--amount">
      <label for="expenses_<%= index %>_amount"><%= t("expenses.form.amount") %></label>
      <input type="text" name="expenses[<%= index %>][amount]" id="expenses_<%= index %>_amount" value="R$ 0,00" class="form-control moeda">
    </div>

    <div class="expense-modal-field expense-modal-field--paid">
      <input type="hidden" name="expenses[<%= index %>][paid]" value="0">
      <input type="checkbox" name="expenses[<%= index %>][paid]" id="expenses_<%= index %>_paid" value="1" class="form-check-input">
      <label for="expenses_<%= index %>_paid" class="form-check-label"><%= t("expenses.form.paid") %></label>
    </div>

    <div class="expense-modal-field">
      <label for="expenses_<%= index %>_date"><%= t("expenses.form.date") %></label>
      <div class="custom-date-wrapper">
        <input type="text" name="expenses[<%= index %>][date]" id="expenses_<%= index %>_date" class="form-control custom-date" autocomplete="off" placeholder="Selecione a data">
      </div>
    </div>

    <div class="expense-modal-field">
      <label for="expenses_<%= index %>_balance_month"><%= t("expenses.form.balance_month") %></label>
      <div class="custom-date-wrapper">
        <input type="text" name="expenses[<%= index %>][balance_month]" id="expenses_<%= index %>_balance_month" class="form-control custom-date" autocomplete="off" placeholder="Selecione o mês">
      </div>
    </div>

    <div class="expense-modal-field">
      <label for="expenses_<%= index %>_category_id"><%= t("expenses.form.category") %></label>
      <select name="expenses[<%= index %>][category_id]" id="expenses_<%= index %>_category_id" class="form-select">
        <option value="">Selecione</option>
        <% categories.each do |category| %>
          <option value="<%= category.id %>"><%= category.display_name %></option>
        <% end %>
      </select>
    </div>

    <div class="expense-modal-field">
      <label for="expenses_<%= index %>_payment_method"><%= t("expenses.form.payment_method") %></label>
      <select name="expenses[<%= index %>][payment_method]" id="expenses_<%= index %>_payment_method" class="form-select" data-payment-method-select>
        <option value="">Selecione</option>
        <% payment_options.each do |label, value| %>
          <option value="<%= value %>"><%= label %></option>
        <% end %>
      </select>
    </div>

    <div class="expense-modal-field">
      <label for="expenses_<%= index %>_card_id"><%= t("expenses.form.card") %></label>
      <select name="expenses[<%= index %>][card_id]" id="expenses_<%= index %>_card_id" class="form-select">
        <option value="">Selecione</option>
        <% cards.each do |card| %>
          <option value="<%= card.id %>"><%= card.display_name %></option>
        <% end %>
      </select>
    </div>

    <button type="button" class="btn expense-modal-row__remove <%= "is-hidden" unless removable %>" data-remove-expense-row aria-label="Remover despesa">
      <span class="material-symbols-rounded">close</span>
    </button>
  </div>

  <div class="expense-modal-installments" data-installments-section>
    <div class="expense-modal-field">
      <label for="expenses_<%= index %>_current_installment">Parcela Atual</label>
      <input type="number" name="expenses[<%= index %>][current_installment]" id="expenses_<%= index %>_current_installment" value="1" min="1" class="form-control">
    </div>

    <div class="expense-modal-field">
      <label for="expenses_<%= index %>_installments_count">Total de Parcelas</label>
      <input type="number" name="expenses[<%= index %>][installments_count]" id="expenses_<%= index %>_installments_count" value="1" min="1" class="form-control">
    </div>
  </div>
</div>
