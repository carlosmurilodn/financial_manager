<turbo-frame id="modal">
  <div data-modal-size="wide"></div>

  <div class="app-modal-header">
    <div>
      <p class="app-page__eyebrow app-mb-1">Revisão de lançamentos</p>
      <h5 class="app-modal-title">Importar Fatura</h5>
    </div>

    <button type="button" class="app-modal-close" data-close-modal aria-label="Fechar">
      <span aria-hidden="true">&times;</span>
    </button>
  </div>

  <div class="invoice-import-modal">
    <div class="invoice-import-modal__loading" data-invoice-loading>
      <div class="invoice-import-modal__loading-card">
        <div class="app-spinner" role="status" aria-hidden="true"></div>
        <strong>Analisando fatura...</strong>
        <span>A IA local está lendo os lançamentos. A primeira execução pode levar mais tempo.</span>
      </div>
    </div>

    <%= form_with url: analyze_invoice_expenses_path,
                  method: :post,
                  multipart: true,
                  data: { turbo_frame: "modal", stay_modal: true },
                  class: "invoice-import-form" do |f| %>
      <div class="invoice-import-form__field invoice-import-form__field--file">
        <%= f.label :invoice_file, "Arquivo da fatura", class: "app-form-label" %>
        <div class="invoice-file-picker">
          <%= f.file_field :invoice_file, class: "app-form-control", accept: ".pdf,.csv,.txt,.jpg,.jpeg,.png", data: { invoice_file_input: true } %>
          <button type="button"
                  class="app-btn invoice-file-picker__preview"
                  data-invoice-file-preview
                  title="Abrir Arquivo"
                  aria-label="Abrir Arquivo"
                  disabled>
            <span class="material-symbols-rounded" aria-hidden="true">visibility</span>
          </button>
        </div>
        <small class="app-text-muted">CSV/TXT geram prévia local. PDF/imagem usam IA local; informe a senha se a fatura for protegida.</small>
      </div>

      <div class="invoice-import-form__field">
        <%= f.label :card_id, "Cartão padrão", class: "app-form-label" %>
        <%= f.select :card_id,
              options_for_select([["Selecionar cartão", ""]] + @cards.map { |card| [card.name, card.id] }, @selected_card_id),
              {},
              class: "app-form-select" %>
      </div>

      <div class="invoice-import-form__field">
        <%= f.label :due_date, "Vencimento", class: "app-form-label" %>
        <%= f.date_field :due_date, value: @invoice_due_date, class: "app-form-control" %>
      </div>

      <div class="invoice-import-form__field">
        <%= f.label :invoice_password, "Senha da fatura", class: "app-form-label" %>
        <%= f.password_field :invoice_password, class: "app-form-control", autocomplete: "off", placeholder: "Opcional" %>
      </div>

      <div class="invoice-import-form__actions">
        <%= f.button class: "app-btn app-btn--primary app-page__primary-btn invoice-import-form__submit" do %>
          <span class="material-symbols-rounded app-me-1">neurology</span>
          Analisar
        <% end %>
      </div>
    <% end %>

    <% if @invoice_import_errors.present? %>
      <div class="app-alert app-alert--warning">
        <%= @invoice_import_errors.to_sentence %>
      </div>
    <% end %>

    <%= form_with url: confirm_invoice_import_expenses_path,
                  method: :post,
                  data: { turbo_frame: "modal" },
                  class: "app-panel app-panel--table invoice-import-review" do %>
      <div class="invoice-import-review__header">
        <div>
          <p class="app-page__eyebrow app-mb-1">Itens encontrados</p>
          <h6>Revise antes de salvar</h6>
        </div>
        <button type="submit" class="app-btn app-btn--secondary app-page__secondary-btn invoice-import-review__submit" <%= "disabled" if @invoice_preview_items.blank? %>>
          <span class="material-symbols-rounded app-me-1">add_task</span>
          Salvar lançamentos
        </button>
      </div>

      <% if @invoice_preview_items.present? %>
        <div class="invoice-import-list">
          <% @invoice_preview_items.each_with_index do |item, index| %>
            <div class="invoice-import-item">
              <div class="invoice-import-item__check">
                <%= hidden_field_tag "invoice_items[#{index}][selected]", "0" %>
                <%= check_box_tag "invoice_items[#{index}][selected]", "1", item[:selected].blank? || ActiveModel::Type::Boolean.new.cast(item[:selected]), class: "app-form-check-input", id: "invoice_items_#{index}_selected" %>
                <%= label_tag "invoice_items_#{index}_selected", "Importar", class: "app-form-check-label" %>
              </div>

              <div class="invoice-import-item__fields">
                <div class="invoice-import-item__row invoice-import-item__row--main">
                  <div class="invoice-import-field invoice-import-field--description">
                    <%= label_tag "invoice_items_#{index}_description", "Descrição" %>
                    <%= text_field_tag "invoice_items[#{index}][description]", item[:description], class: "app-form-control app-form-control--sm", id: "invoice_items_#{index}_description", required: true %>
                  </div>

                  <div class="invoice-import-field">
                    <%= label_tag "invoice_items_#{index}_amount", "Valor" %>
                    <%= text_field_tag "invoice_items[#{index}][amount]", item[:amount], class: "app-form-control app-form-control--sm moeda", id: "invoice_items_#{index}_amount", required: true %>
                  </div>

                  <div class="invoice-import-field">
                    <%= label_tag "invoice_items_#{index}_date", "Data" %>
                    <%= text_field_tag "invoice_items[#{index}][date]", item[:date], class: "app-form-control app-form-control--sm", id: "invoice_items_#{index}_date", required: true %>
                  </div>
                </div>

                <div class="invoice-import-item__row invoice-import-item__row--details">
                  <div class="invoice-import-field">
                    <%= label_tag "invoice_items_#{index}_due_date", "Vencimento" %>
                    <%= date_field_tag "invoice_items[#{index}][due_date]", item[:due_date], class: "app-form-control app-form-control--sm", id: "invoice_items_#{index}_due_date" %>
                  </div>

                  <div class="invoice-import-field">
                    <%= label_tag "invoice_items_#{index}_category_id", "Categoria" %>
                    <%= select_tag "invoice_items[#{index}][category_id]",
                          options_for_select([["Selecione", ""]] + @categories.map { |category| [category.display_name, category.id] }, item[:category_id]),
                          class: "app-form-select app-form-select--sm",
                          id: "invoice_items_#{index}_category_id",
                          required: true %>
                  </div>

                  <div class="invoice-import-field">
                    <span class="invoice-import-field__label">Pagamento</span>
                    <div class="invoice-import-payment">
                      <%= select_tag "invoice_items[#{index}][payment_method]",
                            options_for_select(Expense.payment_method_names.map { |key, label| [label, key] }, item[:payment_method]),
                            class: "app-form-select app-form-select--sm",
                            aria: { label: "Forma de pagamento" },
                            required: true %>
                      <%= select_tag "invoice_items[#{index}][card_id]",
                            options_for_select([["Sem cartão", ""]] + @cards.map { |card| [card.name, card.id] }, item[:card_id]),
                            class: "app-form-select app-form-select--sm",
                            aria: { label: "Cartão" } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="invoice-import-empty">
          Envie uma fatura para gerar a prévia dos lançamentos.
        </div>
      <% end %>
    <% end %>
  </div>
</turbo-frame>
