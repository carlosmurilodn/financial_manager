<turbo-frame id="modal">
  <div data-modal-size="wide"></div>

  <div class="modal-header">
    <div>
      <p class="app-page__eyebrow mb-1">Revisão de lançamentos</p>
      <h5 class="modal-title">Importar Fatura</h5>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
  </div>

  <div class="modal-body p-3 invoice-import-modal">
    <div class="invoice-import-modal__loading" data-invoice-loading>
      <div class="invoice-import-modal__loading-card">
        <div class="spinner-border" role="status" aria-hidden="true"></div>
        <strong>Analisando fatura...</strong>
        <span>A IA local está lendo os lançamentos. A primeira execução pode levar mais tempo.</span>
      </div>
    </div>

    <%= form_with url: analyze_invoice_expenses_path,
                  method: :post,
                  multipart: true,
                  data: { turbo_frame: "modal", stay_modal: true },
                  class: "row g-3 mb-4" do |f| %>
      <div class="col-lg-4">
        <%= f.label :invoice_file, "Arquivo da fatura", class: "form-label" %>
        <div class="invoice-file-picker">
          <%= f.file_field :invoice_file, class: "form-control", accept: ".pdf,.csv,.txt,.jpg,.jpeg,.png", data: { invoice_file_input: true } %>
          <button type="button"
                  class="btn invoice-file-picker__preview"
                  data-invoice-file-preview
                  data-bs-toggle="tooltip"
                  data-bs-title="Abrir Arquivo"
                  aria-label="Abrir Arquivo"
                  disabled>
            <span class="material-symbols-rounded" aria-hidden="true">visibility</span>
          </button>
        </div>
        <small class="text-muted">CSV/TXT geram prévia local. PDF/imagem usam IA local; informe a senha se a fatura for protegida.</small>
      </div>

      <div class="col-lg-2">
        <%= f.label :card_id, "Cartão padrão", class: "form-label" %>
        <%= f.select :card_id,
              options_for_select([["Selecionar cartão", ""]] + @cards.map { |card| [card.name, card.id] }, @selected_card_id),
              {},
              class: "form-select" %>
      </div>

      <div class="col-lg-2">
        <%= f.label :due_date, "Vencimento", class: "form-label" %>
        <%= f.date_field :due_date, value: @invoice_due_date, class: "form-control" %>
      </div>

      <div class="col-lg-2">
        <%= f.label :invoice_password, "Senha da fatura", class: "form-label" %>
        <%= f.password_field :invoice_password, class: "form-control", autocomplete: "off", placeholder: "Opcional" %>
      </div>

      <div class="col-lg-2 d-flex align-items-center" style="padding-bottom: 15px;">
        <%= f.button class: "btn app-page__primary-btn w-100", style: "color: var(--nav-active-icon-color) !important; background: var(--hero-badge-icon-bg) !important; display: flex; justify-content: center; align-items: center;" do %>
          <span class="material-symbols-rounded me-1">neurology</span>
          Analisar
        <% end %>
      </div>
    <% end %>

    <% if @invoice_import_errors.present? %>
      <div class="alert alert-warning py-2 mb-3">
        <%= @invoice_import_errors.to_sentence %>
      </div>
    <% end %>

    <%= form_with url: confirm_invoice_import_expenses_path,
                  method: :post,
                  data: { turbo_frame: "modal" },
                  class: "app-panel app-panel--table mb-0" do %>
      <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
        <div>
          <p class="app-page__eyebrow mb-1">Itens encontrados</p>
          <h6 class="mb-0">Revise antes de salvar</h6>
        </div>
        <button type="submit" class="btn app-page__secondary-btn" style="color: var(--nav-active-icon-color) !important; background: var(--hero-badge-icon-bg) !important; display: flex; justify-content: center; align-items: center;" <%= "disabled" if @invoice_preview_items.blank? %>>
          <span class="material-symbols-rounded me-1">add_task</span>
          Salvar lançamentos
        </button>
      </div>

      <% if @invoice_preview_items.present? %>
        <div class="invoice-import-list">
          <% @invoice_preview_items.each_with_index do |item, index| %>
            <div class="invoice-import-item">
              <div class="invoice-import-item__check">
                <%= hidden_field_tag "invoice_items[#{index}][selected]", "0" %>
                <%= check_box_tag "invoice_items[#{index}][selected]", "1", item[:selected].blank? || ActiveModel::Type::Boolean.new.cast(item[:selected]), class: "form-check-input", id: "invoice_items_#{index}_selected" %>
                <%= label_tag "invoice_items_#{index}_selected", "Importar", class: "form-check-label" %>
              </div>

              <div class="invoice-import-item__fields">
                <div class="invoice-import-item__row invoice-import-item__row--main">
                  <div class="invoice-import-field invoice-import-field--description">
                    <%= label_tag "invoice_items_#{index}_description", "Descrição" %>
                    <%= text_field_tag "invoice_items[#{index}][description]", item[:description], class: "form-control form-control-sm", id: "invoice_items_#{index}_description", required: true %>
                  </div>

                  <div class="invoice-import-field">
                    <%= label_tag "invoice_items_#{index}_amount", "Valor" %>
                    <%= text_field_tag "invoice_items[#{index}][amount]", item[:amount], class: "form-control form-control-sm moeda", id: "invoice_items_#{index}_amount", required: true %>
                  </div>

                  <div class="invoice-import-field">
                    <%= label_tag "invoice_items_#{index}_date", "Data" %>
                    <%= text_field_tag "invoice_items[#{index}][date]", item[:date], class: "form-control form-control-sm", id: "invoice_items_#{index}_date", required: true %>
                  </div>
                </div>

                <div class="invoice-import-item__row invoice-import-item__row--details">
                  <div class="invoice-import-field">
                    <%= label_tag "invoice_items_#{index}_due_date", "Vencimento" %>
                    <%= date_field_tag "invoice_items[#{index}][due_date]", item[:due_date], class: "form-control form-control-sm", id: "invoice_items_#{index}_due_date" %>
                  </div>

                  <div class="invoice-import-field">
                    <%= label_tag "invoice_items_#{index}_category_id", "Categoria" %>
                    <%= select_tag "invoice_items[#{index}][category_id]",
                          options_for_select([["Selecione", ""]] + @categories.map { |category| [category.display_name, category.id] }, item[:category_id]),
                          class: "form-select form-select-sm",
                          id: "invoice_items_#{index}_category_id",
                          required: true %>
                  </div>

                  <div class="invoice-import-field">
                    <span class="invoice-import-field__label">Pagamento</span>
                    <div class="invoice-import-payment">
                      <%= select_tag "invoice_items[#{index}][payment_method]",
                            options_for_select(Expense.payment_method_names.map { |key, label| [label, key] }, item[:payment_method]),
                            class: "form-select form-select-sm",
                            aria: { label: "Forma de pagamento" },
                            required: true %>
                      <%= select_tag "invoice_items[#{index}][card_id]",
                            options_for_select([["Sem cartão", ""]] + @cards.map { |card| [card.name, card.id] }, item[:card_id]),
                            class: "form-select form-select-sm",
                            aria: { label: "Cartão" } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="invoice-import-empty">
          Envie uma fatura para gerar a prévia dos lançamentos.
        </div>
      <% end %>
    <% end %>
  </div>
</turbo-frame>
