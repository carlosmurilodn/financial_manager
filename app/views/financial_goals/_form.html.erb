<%= form_with model: financial_goal, local: true, html: { data: { financial_goal_form: true } } do |f| %>
  <% if financial_goal.errors.any? %>
    <div class="alert alert-danger">
      <strong>Revise os campos destacados.</strong>
    </div>
  <% end %>

  <div class="row mb-3">
    <div class="col-md-7">
      <%= f.label :description, "Descricao" %>
      <%= f.text_field :description, class: "form-control", autofocus: true, required: true %>
    </div>

    <div class="col-md-5">
      <%= f.label :target_amount, "Valor alvo" %>
      <%= f.text_field :target_amount,
            class: "form-control moeda",
            value: number_to_currency(financial_goal.target_amount || 0, unit: "R$", separator: ",", delimiter: "."),
            required: true,
            data: { required_currency: true } %>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-3">
      <%= f.label :current_amount, "Valor atual" %>
      <%= f.text_field :current_amount,
            class: "form-control moeda",
            value: number_to_currency(financial_goal.current_amount || 0, unit: "R$", separator: ",", delimiter: ".") %>
    </div>

    <div class="col-md-3">
      <%= f.label :category_id, "Categoria" %>
      <%= f.collection_select :category_id,
            @categories || [],
            :id,
            :display_name,
            { include_blank: "Sem categoria" },
            class: "form-select" %>
    </div>

    <div class="col-md-3">
      <%= f.label :due_date, "Data prevista" %>
      <%= f.date_field :due_date, class: "form-control", required: true %>
    </div>

    <div class="col-md-3">
      <%= f.label :status, "Status" %>
      <%= f.select :status,
            FinancialGoal.statuses.keys.map { |status| [FinancialGoal::STATUS_LABELS.fetch(status), status] },
            {},
            class: "form-select",
            required: true %>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-3">
      <%= f.label :priority, "Prioridade" %>
      <%= f.select :priority,
            FinancialGoal.priorities.keys.map { |priority| [FinancialGoal::PRIORITY_LABELS.fetch(priority), priority] },
            {},
            class: "form-select",
            required: true %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :notes, "Observacoes" %>
    <%= f.text_area :notes, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3">
    <div class="app-goal-resource-form__header">
      <strong>Composicao dos Recursos</strong>
      <small>Recursos proprios e externos contam no progresso. Limite de credito fica separado como potencial.</small>
    </div>

    <div class="app-goal-resource-form__rows" data-goal-resource-rows>
      <%= f.fields_for :financial_goal_resources do |resource_fields| %>
        <%= render "resource_fields", resource_fields: resource_fields %>
      <% end %>
    </div>

    <template data-goal-resource-template>
      <%= f.fields_for :financial_goal_resources, FinancialGoalResource.new, child_index: "NEW_RECORD" do |resource_fields| %>
        <%= render "resource_fields", resource_fields: resource_fields %>
      <% end %>
    </template>

    <button type="button" class="btn btn-primary expense-modal-action-btn" data-add-goal-resource-row>
      <span class="material-symbols-rounded">add_circle</span>
      Inserir Recurso
    </button>
  </div>

  <div class="mb-3">
    <%= f.submit "Salvar Objetivo", class: "btn btn-primary" %>
  </div>
<% end %>
