<div class="row mb-5">
  <div class="col-12">
    <div class="card shadow">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <%= link_to "← Mês anterior",
              root_path(month: @month - 1 == 0 ? 12 : @month - 1,
                        year: @month - 1 == 0 ? @year - 1 : @year),
              class: "btn btn-outline-secondary btn-sm" %>

          <h4 class="mb-0 fw-bold text-capitalize">
            <%= I18n.l(Date.new(@year, @month, 1), format: "%B de %Y") %>
          </h4>

          <%= link_to "Próximo mês →",
              root_path(month: @month + 1 == 13 ? 1 : @month + 1,
                        year: @month + 1 == 13 ? @year + 1 : @year),
              class: "btn btn-outline-secondary btn-sm" %>
        </div>

        <div class="table-responsive">
          <table class="table table-bordered text-center align-middle shadow-sm">
            <thead class="table-light">
              <tr>
                <th>Dom</th>
                <th>Seg</th>
                <th>Ter</th>
                <th>Qua</th>
                <th>Qui</th>
                <th>Sex</th>
                <th>Sáb</th>
              </tr>
            </thead>
            <tbody>
              <% first_day = Date.new(@year, @month, 1) %>
              <% last_day = first_day.end_of_month %>
              <% start_date = first_day.beginning_of_week(:sunday) %>
              <% end_date = last_day.end_of_week(:sunday) %>
              <% weeks = (start_date..end_date).to_a.in_groups_of(7) %>

              <% weeks.each do |week| %>
                <tr>
                  <% week.each do |date| %>
                    <% if date.nil? || date.month != @month %>
                      <td class="bg-light text-muted"></td>
                    <% else %>
                      <% despesas_dia = @calendar_expenses_not_paid.select { |e| e.date == date } %>
                      <% parcelas_dia = @calendar_installments_not_paid.select { |p| p.due_date == date } %>

                      <td style="vertical-align: top; min-width: 150px;">
                        <div class="fw-bold mb-1"><%= date.day %></div>

                        <% (despesas_dia + parcelas_dia).each do |item| %>
                          <% valor = item.respond_to?(:amount) ? item.amount : item.value %>
                          <% desc = item.try(:description) || item.try(:expense)&.description %>
                          <% categoria = item.try(:category) || item.try(:expense)&.category %>

                          <div class="mt-1 p-1 rounded text-white small" style="background-color: #dc3545;">
                            <%= categoria&.emoji %> <%= desc.presence || "Sem descrição" %><br>
                            <strong><%= number_to_currency(valor, unit: "R$ ", separator: ",", delimiter: ".") %></strong>
                          </div>
                        <% end %>

                        <% if (despesas_dia + parcelas_dia).empty? %>
                          <span class="text-muted small">-</span>
                        <% end %>
                      </td>
                    <% end %>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
