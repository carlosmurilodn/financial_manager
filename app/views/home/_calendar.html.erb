<div class="row">
  <div class="col-12">
    <div class="card shadow">
      <div class="card-body">
        
        <turbo-frame id="calendar">
          
          <div class="d-flex justify-content-between align-items-center mb-3">
            <% # Botão Mês anterior %>
            <%= link_to "← Mês anterior",
                root_path(month: @month - 1 == 0 ? 12 : @month - 1,
                          year: @month - 1 == 0 ? @year - 1 : @year),
                class: "btn btn-secondary btn-lg",
                data: { turbo_frame: "calendar", turbo_prefetch: "false" } %> <%# <-- Adicionado data-turbo-frame %>

            <h4 class="mb-0 fw-bold text-capitalize">
              <%= I18n.l(Date.new(@year, @month, 1), format: "%B de %Y") %>
            </h4>

            <% # Botão Próximo mês %>
            <%= link_to "Próximo mês →",
                root_path(month: @month + 1 == 13 ? 1 : @month + 1,
                          year: @month + 1 == 13 ? @year + 1 : @year),
                class: "btn btn-secondary btn-lg",
                data: { turbo_frame: "calendar", turbo_prefetch: "false" } %> <%# <-- Adicionado data-turbo-frame %>
          </div>

          <div class="table-responsive">
            <table class="table table-bordered text-center align-middle shadow-sm">
              <thead class="table-secondary">
                <tr>
                  <th>Dom</th>
                  <th>Seg</th>
                  <th>Ter</th>
                  <th>Qua</th>
                  <th>Qui</th>
                  <th>Sex</th>
                  <th>Sáb</th>
                </tr>
              </thead>
              <tbody>
                <% @calendar_weeks.each do |week| %>
                  <tr>
                    <% week.each do |date| %>
                      <% if date.nil? || date.month != @month %>
                        <td class="bg-light text-muted"></td>
                      <% else %>
                        <% daily_items = @daily_expenses[date] || [] %>
                        <% day_class = date.wday == 0 ? "text-danger" : "" %>

                        <td style="vertical-align: top; min-width: 150px;">
                          <div class="fw-bold mb-1 fs-5 <%= day_class %>"><%= date.day %></div>

                          <% daily_items.each do |item| %>
                            <div class="mt-1 p-1 rounded text-white small" style="background-color: #FF6B6B;">
                              <%= item[:category_emoji] %> <%= item[:description].presence || "Sem descrição" %><br>
                              <strong><%= number_to_currency(item[:amount], unit: "R$ ", separator: ",", delimiter: ".") %></strong>
                            </div>
                          <% end %>

                          <% if daily_items.empty? %>
                            <span class="text-muted small"></span>
                          <% end %>
                        </td>
                      <% end %>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

        </turbo-frame> <%# <--- FIM DO TURBO FRAME %>

      </div>
    </div>
  </div>
</div>