<div class="dashboard-card dashboard-card--compact dashboard-card--rose">
  <div class="dashboard-card__header">
    <div>
      <p class="dashboard-card__eyebrow">Movimentacoes</p>
      <h2 class="dashboard-card__title">Despesas Recentes</h2>
    </div>

    <div class="dashboard-card__pill dashboard-card__pill--danger">
      <span class="material-symbols-rounded">north_east</span>
      <span>Saidas</span>
    </div>
  </div>

  <div class="dashboard-card__body dashboard-card__body--movement-feed">
    <div class="dashboard-movement-feed dashboard-movement-feed--expenses">
      <% month_labels = %w[jan fev mar abr mai jun jul ago set out nov dez] %>
      <% @recent_expenses.each do |expense| %>
        <article class="dashboard-movement-item dashboard-movement-item--expense">
          <div class="dashboard-movement-item__date">
            <strong><%= expense.date.strftime("%d") %></strong>
            <span><%= month_labels[expense.date.month - 1] %></span>
          </div>

          <div class="dashboard-movement-item__main">
            <div class="dashboard-movement-item__title">
              <span class="material-symbols-rounded dashboard-movement-item__marker"><%= expense.category&.material_icon || "category" %></span>
              <strong><%= expense.description.presence || "Despesa" %></strong>
            </div>
            <small><%= expense.category&.name || "Sem categoria" %></small>
          </div>

          <strong class="dashboard-movement-item__amount">
            <%= number_to_currency(expense.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
          </strong>
        </article>
      <% end %>
    </div>
  </div>
</div>
