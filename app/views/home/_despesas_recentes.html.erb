<div class="dashboard-card dashboard-card--compact dashboard-card--rose">
  <div class="dashboard-card__header">
    <div>
      <p class="dashboard-card__eyebrow">Movimentacoes</p>
      <h2 class="dashboard-card__title">Despesas recentes</h2>
    </div>

    <div class="dashboard-card__pill dashboard-card__pill--danger">
      <span class="material-symbols-rounded">north_east</span>
      <span>Saidas</span>
    </div>
  </div>

  <div class="dashboard-card__body">
    <% linhas = @recent_expenses.size + 1 %>
    <% altura_linha = 100.0 / linhas %>

    <table class="table app-table mb-0" style="height: 100%; table-layout: fixed;">
      <thead>
        <tr style="height: <%= altura_linha %>%;">
          <th class="align-middle">Data</th>
          <th class="align-middle">Descricao</th>
          <th class="align-middle">Valor</th>
        </tr>
      </thead>

      <tbody>
        <% @recent_expenses.each_with_index do |expense, index| %>
          <% borda = (index == @recent_expenses.size - 1) ? "none" : "1px solid rgba(239, 68, 68, 0.16)" %>
          <tr style="height: <%= altura_linha %>%;">
            <td class="text-start align-middle" style="border-bottom: <%= borda %>;">
              <%= expense.date.strftime("%d/%m/%Y") %>
            </td>
            <td class="text-start align-middle" style="border-bottom: <%= borda %>;">
              <%= expense.category.emoji %> <%= expense.description %>
            </td>
            <td class="text-start align-middle text-danger" style="border-bottom: <%= borda %>;">
              <%= number_to_currency(expense.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
