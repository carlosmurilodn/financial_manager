<div class="card shadow" style="height: 400px;">
  <div class="card-body d-flex flex-column h-100 p-3">
    <h5 class="card-title text-center mb-3">Despesas Recentes</h5>

    <% despesas = Expense.order(date: :desc).limit(7) %>
    <% linhas = despesas.size + 1 %>
    <% altura_linha = 100.0 / linhas %>

    <table class="table table-borderless text-dark mb-0" style="height: 100%; table-layout: fixed; border-collapse: collapse;">
      <thead>
        <tr style="height: <%= altura_linha %>%;">
          <th class="align-middle" style="border-bottom: 2px solid #dc3545;">Data</th>
          <th class="align-middle" style="border-bottom: 2px solid #dc3545;">Descrição</th>
          <th class="align-middle" style="border-bottom: 2px solid #dc3545;">Valor</th>
        </tr>
      </thead>

      <tbody>
        <% despesas.each_with_index do |expense, index| %>
          <% borda = (index == despesas.size - 1) ? "none" : "1px solid #dc3545" %>
          <tr style="height: <%= altura_linha %>%;">
            <td class="text-start align-middle" style="border-bottom: <%= borda %>;">
              <%= expense.date.strftime("%d/%m/%Y") %>
            </td>
            <td class="text-start align-middle" style="border-bottom: <%= borda %>;">
              <%= expense.category.emoji %> <%= expense.description %>
            </td>
            <td class="text-start align-middle text-danger" style="border-bottom: <%= borda %>;">
              <%= number_to_currency(expense.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>