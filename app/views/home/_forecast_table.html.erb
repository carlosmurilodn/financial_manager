<div class="dashboard-card">
  <div class="dashboard-card__header">
    <div>
      <p class="dashboard-card__eyebrow">Planejamento</p>
      <h2 class="dashboard-card__title">Previsao financeira anual</h2>
    </div>

    <div class="dashboard-card__pill">
      <span class="material-symbols-rounded">query_stats</span>
      <span>Projecao</span>
    </div>
  </div>

  <div class="dashboard-card__body">
    <turbo-frame id="forecast-table">
      <div class="dashboard-toolbar">
        <% prev_year = year - 1 %>
        <% next_year = year + 1 %>

        <div class="dashboard-toolbar__actions">
          <%= link_to "← Ano anterior",
              root_path(year: prev_year),
              class: "btn app-btn app-btn--ghost",
              data: { turbo_frame: "forecast-table", turbo_prefetch: "false" } %>
        </div>

        <h5 class="fw-bold mb-0">Previsao financeira - <%= year %></h5>

        <div class="dashboard-toolbar__actions">
          <%= link_to "Próximo ano →",
              root_path(year: next_year),
              class: "btn app-btn app-btn--ghost",
              data: { turbo_frame: "forecast-table", turbo_prefetch: "false" } %>
        </div>
      </div>

      <div class="table-responsive">
        <table class="table app-table app-table--forecast text-center align-middle">
          <thead>
            <tr>
              <th>Mes</th>
              <th>Receitas</th>
              <th>Despesas</th>
              <th>Saldo</th>
            </tr>
          </thead>
          <tbody>
            <% months.each do |month| %>
              <% data = @forecast_data[month] %>
              <tr>
                <td><%= I18n.l(Date.new(year, month, 1), format: "%B") %></td>
                <td class="text-success fw-semibold">
                  <%= number_to_currency(data[:receitas], unit: "R$ ", separator: ",", delimiter: ".") %>
                </td>
                <td class="text-danger fw-semibold">
                  <%= number_to_currency(data[:despesas], unit: "R$ ", separator: ",", delimiter: ".") %>
                </td>
                <td class="<%= data[:saldo] >= 0 ? 'text-success' : 'text-danger' %> fw-bold">
                  <%= number_to_currency(data[:saldo], unit: "R$ ", separator: ",", delimiter: ".") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </turbo-frame>
  </div>
</div>
