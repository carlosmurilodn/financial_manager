<div class="kpi-grid">
  <div class="stat-card stat-card--success">
    <div class="stat-card__icon">
      <span class="material-symbols-rounded">account_balance_wallet</span>
    </div>
    <div>
      <span class="stat-card__label">Saldo Atual</span>
      <strong class="stat-card__value">
        <%= number_to_currency(@saldo_atual, unit: "R$ ", separator: ",", delimiter: ".") %>
      </strong>
      <small class="stat-card__meta">Panorama consolidado das contas</small>
    </div>
  </div>

  <div class="stat-card stat-card--primary">
    <div class="stat-card__icon">
      <span class="material-symbols-rounded">trending_up</span>
    </div>
    <div>
      <span class="stat-card__label">Receitas de <%= I18n.l(Date.current, format: "%B") %></span>
      <strong class="stat-card__value">
        <%= number_to_currency(@receitas_mes, unit: "R$ ", separator: ",", delimiter: ".") %>
      </strong>
      <small class="stat-card__meta">Entradas registradas no mes</small>
    </div>
  </div>

  <div class="stat-card stat-card--danger">
    <div class="stat-card__icon">
      <span class="material-symbols-rounded">trending_down</span>
    </div>
    <div>
      <span class="stat-card__label">Despesas de <%= I18n.l(Date.current, format: "%B") %></span>
      <strong class="stat-card__value">
        <%= number_to_currency(@despesas_mes, unit: "R$ ", separator: ",", delimiter: ".") %>
      </strong>
      <small class="stat-card__meta">Saidas acumuladas no mes</small>
    </div>
  </div>

  <div class="stat-card stat-card--warning">
    <div class="stat-card__icon">
      <span class="material-symbols-rounded">finance</span>
    </div>
    <div>
      <span class="stat-card__label">Saldo Liquido</span>
      <strong class="stat-card__value">
        <%= number_to_currency(@saldo_liquido, unit: "R$ ", separator: ",", delimiter: ".") %>
      </strong>
      <small class="stat-card__meta">Diferenca entre entradas e saidas</small>
    </div>
  </div>
</div>
