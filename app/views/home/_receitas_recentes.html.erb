<div class="dashboard-card dashboard-card--compact dashboard-card--peach">
  <div class="dashboard-card__header">
    <div>
      <p class="dashboard-card__eyebrow">Movimentacoes</p>
      <h2 class="dashboard-card__title">Receitas recentes</h2>
    </div>

    <div class="dashboard-card__pill dashboard-card__pill--success">
      <span class="material-symbols-rounded">south_west</span>
      <span>Entradas</span>
    </div>
  </div>

  <div class="dashboard-card__body">
    <% receitas = @recent_incomes %>
    <% linhas = receitas.size + 1 %>
    <% altura_linha = 100.0 / linhas %>

    <table class="table app-table mb-0" style="height: 100%; table-layout: fixed;">
      <thead>
        <tr style="height: <%= altura_linha %>%;">
          <th class="align-middle">Data</th>
          <th class="align-middle">Descricao</th>
          <th class="align-middle">Valor</th>
        </tr>
      </thead>

      <tbody>
        <% receitas.each_with_index do |income, index| %>
          <% borda = (index == receitas.size - 1) ? "none" : "1px solid rgba(34, 197, 94, 0.18)" %>
          <tr style="height: <%= altura_linha %>%;">
            <td class="text-start align-middle" style="border-bottom: <%= borda %>;">
              <%= income.date.strftime("%d/%m/%Y") %>
            </td>
            <td class="text-start align-middle" style="border-bottom: <%= borda %>;">
              <%= income.description.presence || "Receita" %>
            </td>
            <td class="text-start align-middle text-success" style="border-bottom: <%= borda %>;">
              <%= number_to_currency(income.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
