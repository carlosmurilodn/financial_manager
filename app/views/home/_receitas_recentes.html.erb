<div class="dashboard-card dashboard-card--compact dashboard-card">
  <div class="dashboard-card__header">
    <div>
      <p class="dashboard-card__eyebrow">Movimentacoes</p>
      <h2 class="dashboard-card__title">Receitas Recentes</h2>
    </div>

    <div class="dashboard-card__pill dashboard-card__pill--success">
      <span class="material-symbols-rounded">south_west</span>
      <span>Entradas</span>
    </div>
  </div>

  <div class="dashboard-card__body dashboard-card__body--movement-feed">
    <% receitas = @recent_incomes %>

    <div class="dashboard-movement-feed dashboard-movement-feed--incomes">
      <% month_labels = %w[jan fev mar abr mai jun jul ago set out nov dez] %>
      <% receitas.each do |income| %>
        <article class="dashboard-movement-item dashboard-movement-item--income">
          <div class="dashboard-movement-item__date">
            <strong><%= income.date.strftime("%d") %></strong>
            <span><%= month_labels[income.date.month - 1] %></span>
          </div>

          <div class="dashboard-movement-item__main">
            <div class="dashboard-movement-item__title">
              <span class="material-symbols-rounded dashboard-movement-item__marker"><%= income.category&.material_icon || "category" %></span>
              <strong><%= income.description.presence || "Receita" %></strong>
            </div>
            <small><%= income.category&.name || "Sem categoria" %></small>
          </div>

          <strong class="dashboard-movement-item__amount">
            <%= number_to_currency(income.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
          </strong>
        </article>
      <% end %>
    </div>
  </div>
</div>
