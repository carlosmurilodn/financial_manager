<div class="dashboard-card dashboard-card--chart dashboard-card--lavender">
  <div class="dashboard-card__header">
    <div>
      <p class="dashboard-card__eyebrow">Cartoes</p>
      <h2 class="dashboard-card__title">Saldo acumulado por cartao</h2>
    </div>

    <div class="dashboard-card__pill">
      <span class="material-symbols-rounded">credit_card</span>
      <span><%= I18n.l(Date.current, format: "%B") %></span>
    </div>
  </div>

  <div class="dashboard-card__body">
    <% linhas = @cards_info.size + 1 %>
    <% altura_linha = 100.0 / linhas %>

    <table class="table app-table mb-0" style="height: 100%; table-layout: fixed;">
      <thead>
        <tr style="height: <%= altura_linha %>%;">
          <th class="align-middle">Cartao</th>
          <th class="align-middle">Limite total</th>
          <th class="align-middle">Limite restante</th>
          <th class="align-middle">Saldo acumulado</th>
        </tr>
      </thead>

      <tbody>
        <% @cards_info.each_with_index do |info, index| %>
          <% card = info[:card] %>
          <% total = info[:total] %>
          <% borda = (index == @cards_info.size - 1) ? "none" : "1px solid rgba(148, 163, 184, 0.22)" %>
          <tr style="height: <%= altura_linha %>%;">
            <td class="text-start align-middle" style="border-bottom: <%= borda %>;">
              <div class="app-table__primary">
                <span class="app-table__avatar">
                  <%= card.icon.attached? ? image_tag(card.icon, width: 20) : "💳" %>
                </span>
                <span><%= card.name %></span>
              </div>
            </td>
            <td class="text-start align-middle text-success" style="border-bottom: <%= borda %>;">
              <%= number_to_currency(card.total_limit, unit: "R$ ", separator: ",", delimiter: ".") %>
            </td>
            <td class="text-start align-middle text-success" style="border-bottom: <%= borda %>;">
              <%= number_to_currency(card.remaining_limit, unit: "R$ ", separator: ",", delimiter: ".") %>
            </td>
            <td class="text-start align-middle text-danger" style="border-bottom: <%= borda %>;">
              <%= number_to_currency(total, unit: "R$ ", separator: ",", delimiter: ".") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
