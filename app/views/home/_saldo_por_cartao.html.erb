<turbo-frame id="card-balance-summary">
<div class="dashboard-card dashboard-card--chart dashboard-card--lavender dashboard-card--cards-summary">
  <div class="dashboard-card__header">
    <div>
      <p class="dashboard-card__eyebrow">Cartoes</p>
      <h2 class="dashboard-card__title">Saldo Acumulado por Cartão</h2>
    </div>

    <div class="dashboard-card__pill dashboard-card__pill--period">
      <%= link_to root_path(card_month: @previous_card_balance_date.month, card_year: @previous_card_balance_date.year),
                  class: "dashboard-card__period-button",
                  aria: { label: "Mês anterior" },
                  data: { turbo_frame: "card-balance-summary", turbo_prefetch: "false" } do %>
        <span class="material-symbols-rounded">chevron_left</span>
      <% end %>
      <span class="dashboard-card__period-label">
        <span class="material-symbols-rounded">credit_card</span>
        <span><%= I18n.l(@card_balance_date, format: "%B de %Y") %></span>
      </span>
      <%= link_to root_path(card_month: @next_card_balance_date.month, card_year: @next_card_balance_date.year),
                  class: "dashboard-card__period-button",
                  aria: { label: "Próximo mês" },
                  data: { turbo_frame: "card-balance-summary", turbo_prefetch: "false" } do %>
        <span class="material-symbols-rounded">chevron_right</span>
      <% end %>
    </div>
  </div>

  <div class="dashboard-card__body dashboard-card__body--cards-summary">
    <div class="dashboard-cards-list">
      <% @cards_info.each do |info| %>
        <% card = info[:card] %>
        <% total = info[:total].to_f %>
        <% total_limit = card.total_limit.to_f %>
        <% remaining_limit = info[:remaining_limit].to_f %>
        <% card_expenses = info[:items] || [] %>
        <% card_expenses_total = card_expenses.sum { |expense| expense[:amount].to_f } %>
        <% month_total = info[:month_total].to_f %>
        <% month_paid = info[:month_paid] %>
        <% month_status_class = month_paid ? "is-positive" : "is-negative" %>
        <% usage_percent = total_limit.positive? ? [(total / total_limit) * 100, 100].min : 0 %>
        <% remaining_percent = total_limit.positive? ? [(remaining_limit / total_limit) * 100, 0].max : 0 %>

        <article class="dashboard-card-balance <%= "dashboard-card-balance--clickable" if card_expenses.any? %>">
          <div class="dashboard-card-balance__usage">
            <div class="dashboard-card-balance__header">
              <div class="dashboard-card-balance__identity">
                <span class="dashboard-card-balance__avatar">
                  <% if card.icon.attached? %>
                    <%= image_tag(card.icon, alt: card.name, class: "dashboard-card-balance__avatar-image") %>
                  <% else %>
                    <span class="dashboard-card-balance__avatar-fallback"><%= card.name.to_s.first(2).upcase %></span>
                  <% end %>
                </span>
                <div class="dashboard-card-balance__copy">
                  <strong><%= card.name %></strong>
                  <small>Uso atual do limite</small>
                </div>
              </div>

              <div class="dashboard-card-balance__total">
                <span><%= number_to_percentage(usage_percent, precision: 0) %></span>
              </div>
            </div>

            <div class="dashboard-card-balance__progress" role="img" aria-label="Uso de <%= card.name %>: <%= number_to_percentage(usage_percent, precision: 0) %>">
              <span class="dashboard-card-balance__progress-used" style="width: <%= usage_percent.round(1) %>%;"></span>
              <span class="dashboard-card-balance__progress-remaining" style="width: <%= remaining_percent.round(1) %>%;"></span>
            </div>
          </div>

          <div class="dashboard-card-balance__metrics">
            <div>
              <small>Limite total</small>
              <strong class="is-positive"><%= number_to_currency(total_limit, unit: "R$ ", separator: ",", delimiter: ".") %></strong>
            </div>
            <div>
              <small>Limite restante</small>
              <strong class="is-positive"><%= number_to_currency(remaining_limit, unit: "R$ ", separator: ",", delimiter: ".") %></strong>
            </div>
            <div>
              <small>Saldo do mes</small>
              <strong class="<%= month_status_class %>">
                <%= number_to_currency(month_total, unit: "R$ ", separator: ",", delimiter: ".") %>
              </strong>
            </div>
            <div>
              <small>Saldo acumulado</small>
              <div class="dashboard-card-balance__metric-action">
                <strong class="is-negative"><%= number_to_currency(total, unit: "R$ ", separator: ",", delimiter: ".") %></strong>
                <button type="button"
                        class="dashboard-card-balance__toggle"
                        aria-expanded="false"
                        aria-label="Mostrar despesas de <%= card.name %> em <%= I18n.l(@card_balance_date, format: "%B de %Y") %>"
                        <%= "disabled" if card_expenses.blank? %>>
                  <span class="material-symbols-rounded">keyboard_arrow_down</span>
                </button>
              </div>
            </div>
          </div>

          <div class="dashboard-card-balance__details" role="tooltip">
            <div class="dashboard-card-balance__details-header">
              <strong><%= card.name %></strong>
              <span>
                <%= pluralize(card_expenses.size, "despesa", "despesas") %>
                · <%= number_to_currency(card_expenses_total, unit: "R$ ", separator: ",", delimiter: ".") %>
              </span>
            </div>

            <% if card_expenses.any? %>
              <div class="dashboard-card-balance__details-list">
                <% card_expenses.each do |expense| %>
                  <div class="dashboard-card-balance__details-row <%= expense[:paid] ? "dashboard-card-balance__details-row--paid" : "dashboard-card-balance__details-row--pending" %>">
                    <span>
                      <% if expense[:installment_label].present? %>
                        <%= "#{expense[:description]} #{expense[:installment_label]}" %>
                      <% else %>
                        <%= expense[:description] %>
                      <% end %>
                    </span>
                    <strong><%= number_to_currency(expense[:amount], unit: "R$ ", separator: ",", delimiter: ".") %></strong>
                    <small><%= expense[:date].strftime("%d/%m/%Y") %> · <%= expense[:paid] ? "Pago" : "Pendente" %></small>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="dashboard-card-balance__details-empty">
                Nenhuma despesa neste mês de balanço.
              </div>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</div>
</turbo-frame>
