<section class="dashboard-page">
  <div class="dashboard-hero">
    <div>
      <h1>Uma visao mais clara do seu dinheiro</h1>
      <p class="dashboard-description">
        Acompanhe saldo, receitas, despesas e previsoes em um layout mais moderno, leve e facil de ler.
      </p>
    </div>

    <div class="dashboard-hero__badge">
      <div class="dashboard-hero__badge-item dashboard-hero__badge-item--primary">
        <span class="material-symbols-rounded">event_upcoming</span>
        <div>
          <div id="dashboard-current-time" class="app-sidebar__time">
            <span class="app-sidebar__time-main"><%= Time.current.strftime("%H:%M") %></span>
            <span class="app-sidebar__time-seconds">:<%= Time.current.strftime("%S") %></span>
          </div>
          <strong><%= "#{Date.current.day} de #{I18n.l(Date.current, format: '%B').capitalize} de #{Date.current.year}" %></strong>
        </div>
      </div>
      <div id="dashboard-weather-info" class="dashboard-hero__badge-item dashboard-hero__badge-item--weather">
        <div class="today-weather today-weather--dashboard today-weather--placeholder" aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <div class="dashboard-block">
    <%= render "home/kpis" %>
  </div>

  <div class="dashboard-grid dashboard-grid--charts">
    <div class="dashboard-grid__item dashboard-grid__item--movement-stack">
      <%= render "home/receitas_recentes" %>
      <%= render "home/despesas_recentes" %>
    </div>

    <div class="dashboard-grid__item dashboard-grid__item--cards-summary">
      <%= render "home/saldo_por_cartao" %>
    </div>

    <div class="dashboard-grid__item dashboard-grid__item--category-chart">
      <%= render "home/despesas_por_categoria" %>
    </div>
  </div>

  <div class="dashboard-grid dashboard-grid--planning">
    <div class="dashboard-grid__item">
      <%= render "home/calendar" %>
    </div>

    <div class="dashboard-grid__item">
      <%= render "home/forecast_table", year: @year, months: @months %>
    </div>
  </div>
</section>

