<section class="dashboard-page">
  <div class="dashboard-hero">
    <div>
      <p class="dashboard-eyebrow">Painel financeiro</p>
      <h1>Uma visao mais clara do seu dinheiro</h1>
      <p class="dashboard-description">
        Acompanhe saldo, receitas, despesas e previsoes em um layout mais moderno, leve e facil de ler.
      </p>
    </div>

    <div class="dashboard-hero__badge">
      <span class="material-symbols-rounded">monitoring</span>
      <div>
        <strong><%= I18n.l(Date.current, format: "%B de %Y") %></strong>
        <small>Atualizado com os dados do periodo atual</small>
      </div>
    </div>
  </div>

  <div class="dashboard-block">
    <%= render "home/kpis" %>
  </div>

  <div class="dashboard-grid dashboard-grid--charts">
    <div class="dashboard-grid__item dashboard-grid__item--wide">
      <%= render "home/despesas_por_categoria" %>
    </div>

    <div class="dashboard-grid__item">
      <%= render "home/saldo_por_cartao" %>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="dashboard-grid__item">
      <%= render "home/receitas_recentes" %>
    </div>

    <div class="dashboard-grid__item">
      <%= render "home/despesas_recentes" %>
    </div>
  </div>

  <div class="dashboard-grid dashboard-grid--planning">
    <div class="dashboard-grid__item">
      <%= render "home/calendar" %>
    </div>

    <div class="dashboard-grid__item">
      <%= render "home/forecast_table", year: @year, months: @months %>
    </div>
  </div>
</section>

<%= render "home/scripts" %>
