<div class="container-fluid">

  <!-- Cards KPIs -->
  <div class="row mb-4">
    <div class="col-md-3 mb-3">
      <div class="card text-center shadow card-small">
        <div class="card-body">
          <h6 class="card-title text-muted">Saldo Atual</h6>
          <h4 class="text-success">
            <%= number_to_currency(@saldo_atual) %>
          </h4>
        </div>
      </div>
    </div>

    <div class="col-md-3 mb-3">
      <div class="card text-center shadow card-small">
        <div class="card-body">
          <h6 class="card-title text-muted">Receitas de <%= I18n.l(Date.current, format: "%B") %></h6>
          <h4 class="text-primary">
            <%= number_to_currency(@receitas_mes) %>
          </h4>
        </div>
      </div>
    </div>

    <div class="col-md-3 mb-3">
      <div class="card text-center shadow card-small">
        <div class="card-body">
          <h6 class="card-title text-muted">Despesas de <%= I18n.l(Date.current, format: "%B") %></h6>
          <h4 class="text-danger">
            <%= number_to_currency(@despesas_mes) %>
          </h4>
        </div>
      </div>
    </div>

    <div class="col-md-3 mb-3">
      <div class="card text-center shadow card-small">
        <div class="card-body">
          <h6 class="card-title text-muted">Saldo Líquido</h6>
          <h4 class="text-warning">
            <%= number_to_currency(@saldo_liquido) %>
          </h4>
        </div>
      </div>
    </div>
  </div>

  <!-- Gráficos e Saldo por Cartão -->
  <div class="row mb-4">
    <div class="col-lg-6 mb-3">
      <!-- Gráfico de Barras Horizontal -->
      <div class="card shadow">
        <div class="card-body" style="height: 700px;">
          <h5 class="card-title">Despesas por Categoria (<%= I18n.l(Date.current, format: "%B") %>)</h5>
          <canvas id="despesasChart"></canvas>
        </div>
      </div>

      <!-- Saldo por Cartão -->
      <div class="row mb-4 mt-2">
        <div class="col-12">
          <div class="card shadow">
            <div class="card-body">
              <h5 class="card-title">Saldo Acumulado por Cartão (<%= I18n.l(Date.current, format: "%B") %>)</h5>
              <ul class="list-group list-group-flush">
                <% @cards_info.each do |info| %>
                  <% card = info[:card] %>
                  <% total = info[:total] %>
                  <li class="list-group-item d-flex justify-content-between text-dark">
                    <span class="text-start flex-fill">
                      <%= card.icon.present? ? image_tag(card.icon, width: 20, class: "me-2") : "💳" %>
                      <%= card.name %>
                    </span>
                    <span class="text-center flex-fill text-success">
                      <%= number_to_currency(card.total_limit, unit: "R$ ", separator: ",", delimiter: ".") %> +
                    </span>
                    <span class="text-end flex-fill text-danger">
                      <%= number_to_currency(total, unit: "R$ ", separator: ",", delimiter: ".") %>
                    </span>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-6 mb-3">
      <div class="card shadow">
        <div class="card-body">
          <h5 class="card-title">Receitas x Despesas (Últimos 4 meses)</h5>
          <canvas id="receitasChart"></canvas>
        </div>
      </div>

      <!-- Listas Recentes -->
      <div class="colum">
        <div class="col-lg-12 mb-2 mt-2">
          <div class="card shadow">
            <div class="card-body">
              <h5 class="card-title">Despesas Recentes</h5>
              <ul class="list-group list-group-flush">
                <% Expense.order(date: :desc).limit(7).each do |expense| %>
                  <li class="list-group-item d-flex justify-content-between text-dark">
                    <span>
                      <%= expense.date.strftime("%d/%m/%Y") %> - <%= expense.category.emoji %> <%= expense.category.name %> - <%= expense.description %>
                    </span>
                    <span class="text-danger">
                      <%= number_to_currency(expense.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
                    </span>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>

        <div class="col-lg-12 mb-3">
          <div class="card shadow">
            <div class="card-body">
              <h5 class="card-title">Receitas Recentes</h5>
              <ul class="list-group list-group-flush">
                <% Income.order(date: :desc).limit(7).each do |income| %>
                  <li class="list-group-item d-flex justify-content-between text-dark">
                    <span>
                      <%= income.date.strftime("%d/%m/%Y") %> - 
                      <%= income.description.presence || "Receita" %>
                    </span>
                    <span class="text-success"><%= number_to_currency(income.amount, unit: "R$ ", separator: ",", delimiter: ".") %></span>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<script>
  // Gráficos Turbo-friendly
  let despesasChartInstance;
  let receitasChartInstance;

  document.addEventListener("turbo:load", () => {
    const despesasCanvas = document.getElementById('despesasChart');
    const receitasCanvas = document.getElementById('receitasChart');
    if (!despesasCanvas || !receitasCanvas) return;

    if (despesasChartInstance) despesasChartInstance.destroy();
    if (receitasChartInstance) receitasChartInstance.destroy();

    // ==============================
    // --- DISTRIBUIÇÃO DE DESPESAS ---
    // ==============================
    const despesasLabels = <%= raw @despesas_por_categoria.keys.to_json %>;
    const despesasValues = <%= raw @despesas_por_categoria.values.to_json %>;
    const despesasDetalhes = <%= raw @detalhes_despesas_por_categoria.to_json %>;

    despesasChartInstance = new Chart(despesasCanvas.getContext('2d'), {
      type: 'bar',
      data: {
        labels: despesasLabels,
        datasets: [{
          data: despesasValues,
          backgroundColor: [
            '#FF6B6B', '#FFB56B', '#FFD93D', '#6BCB77', '#4D96FF',
            '#845EC2', '#FF70A6', '#00C9A7', '#FFC75F', '#F9F871',
            '#A0CED9', '#FF9671', '#B388EB', '#FFABAB', '#8AC926'
          ],
          borderColor: '#ffffff',
          borderWidth: 2,
          borderRadius: 5
        }]
      },
      options: {
        layout: { padding: { bottom: 30, right: 80 } },
        maintainAspectRatio: false,
        indexAxis: 'y',
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                const index = ctx.dataIndex;                     
                const categoria = ctx.chart.data.labels[index]; 
                const despesas = despesasDetalhes[categoria] || [];

                const valor = `Total: R$ ${ctx.raw.toLocaleString('pt-BR', {
                  minimumFractionDigits: 2,
                  maximumFractionDigits: 2
                })}`;

                if (despesas.length === 0) {
                  return [valor];
                } else {
                  const lista = despesas.map(d => `• ${d}`);
                  return [valor, ...lista]; // cada item = uma linha separada
                }
              }
            }
          },
          datalabels: {
            color: '#343a40',
            anchor: 'end',
            align: 'right',
            font: { weight: 'bold', size: 14 },
            formatter: (value) => `R$ ${Number(value).toLocaleString('pt-BR', {
              minimumFractionDigits: 2,
              maximumFractionDigits: 2
            })}`
          }
        },
        scales: {
          x: {
            beginAtZero: true,
            ticks: {
              color: '#343a40',
              callback: val => 'R$ ' + val.toLocaleString('pt-BR')
            },
            grid: { color: 'rgba(0,0,0,0.05)' }
          },
          y: {
            ticks: { color: '#343a40' },
            grid: { display: false }
          }
        }
      },
      plugins: [ChartDataLabels]
    });

    // ==============================
    // --- RECEITAS X DESPESAS ---
    // ==============================
    const months = <%= raw @meses_labels.to_json %>;
    const receitasValues = <%= raw @receitas_mensais.to_json %>;
    const despesasValuesBar = <%= raw @despesas_mensais.to_json %>;

    receitasChartInstance = new Chart(receitasCanvas.getContext('2d'), {
      type: 'bar',
      data: {
        labels: months,
        datasets: [
          { label: 'Receitas', data: receitasValues, backgroundColor: '#0d6efd', borderRadius: 5 },
          { label: 'Despesas', data: despesasValuesBar, backgroundColor: '#dc3545', borderRadius: 5 }
        ]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'top', labels: { color: '#343a40', font: { size: 14 } } },
          tooltip: {
            callbacks: {
              label: ctx => `${ctx.dataset.label}: R$ ${ctx.raw.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}`
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              color: '#343a40',
              callback: val => 'R$ ' + val.toLocaleString('pt-BR')
            },
            grid: { color: 'rgba(0,0,0,0.05)' }
          },
          x: { ticks: { color: '#343a40' }, grid: { display: false } }
        }
      }
    });
  });
</script>
