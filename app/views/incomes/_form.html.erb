<%= form_with model: income, local: true do |f| %>
  <div class="row app-mb-3">
    <div class="col-md-9">
      <%= f.label :description, t("incomes.form.description") %>
      <%= f.text_field :description, class: "app-form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :repetir, "Repetir (meses)" %>
      <%= f.number_field :repetir, value: @income.repetir || 0, min: 0, class: "app-form-control" %>
    </div>
  </div>

  <div class="row app-mb-3 app-align-end">
    <div class="col-md-4">
      <div class="app-flex app-align-center app-gap-3">
        <div class="app-flex-grow">
          <%= f.label :amount, t("incomes.form.amount") %>
          <%= f.text_field :amount,
            class: "app-form-control moeda",
            value: (income.amount.present? ? number_to_currency(income.amount, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) : "R$ 0,00"),
            required: true,
            data: { required_currency: true }
          %>
        </div>

        <div class="app-form-check app-mb-2">
          <%= f.check_box :paid, class: "app-form-check-input", id: "income_paid" %>
          <%= f.label :paid, t("incomes.form.paid"), class: "app-form-check-label", for: "income_paid" %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <%= f.label :category_id, t("incomes.form.category") %>
      <%= f.collection_select :category_id, Category.order(:name), :id, :display_name, { prompt: "Selecione" }, { class: "app-form-select" } %>
    </div>

    <div class="col-md-4">
      <%= f.label :date, t("incomes.form.date") %>
      <div class="custom-date-wrapper">
        <%= f.text_field :date, class: "app-form-control custom-date", autocomplete: "off", placeholder: "Selecione a data", required: true %>
      </div>
    </div>
  </div>

  <div class="row app-mb-3 app-align-end">
    <div class="col-md-4">
      <%= f.label :balance_month, t("incomes.form.balance_month") %>
      <div class="custom-date-wrapper">
        <%= f.text_field :balance_month, class: "app-form-control custom-date", autocomplete: "off", placeholder: "Selecione o mês", required: true %>
      </div>
    </div>
  </div>

  <div class="app-mb-3">
    <%= f.submit t("incomes.form.submit"), class: "app-btn app-btn--primary" %>
  </div>
<% end %>
