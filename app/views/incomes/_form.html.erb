<%= form_with model: income, local: true do |f| %>
  <div class="row mb-3">
    <div class="col-12">
      <%= f.label :description, t("incomes.form.description") %>
      <%= f.text_field :description, class: "form-control" %>
    </div>
  </div>

  <div class="row mb-3 align-items-end">
    <div class="col-md-4">
      <div class="d-flex align-items-center gap-3">
        <div class="flex-grow-1">
          <%= f.label :amount, t("incomes.form.amount") %>
          <%= f.text_field :amount, 
            class: "form-control moeda", 
            value: (income.amount.present? ? number_to_currency(income.amount, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) : "R$ 0,00")
            # oninput foi removido, a inicialização está em utils.js
          %>
        </div>

        <div class="form-check mb-2">
          <%= f.check_box :paid, class: "form-check-input", id: "income_paid" %>
          <%= f.label :paid, t("incomes.form.paid"), class: "form-check-label ms-1", for: "income_paid" %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <%= f.label :date, t("incomes.form.date") %>
      <div class="custom-date-wrapper">
        <%= f.text_field :date, class: "form-control custom-date", autocomplete: "off", placeholder: "Selecione a data" %>
      </div>
    </div>

    <div class="col-md-4">
      <%= f.label :balance_month, t("incomes.form.balance_month") %>
      <div class="custom-date-wrapper">
        <%= f.text_field :balance_month, class: "form-control custom-date", autocomplete: "off", placeholder: "Selecione o mês" %>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.submit t("incomes.form.submit"), class: "btn btn-primary" %>
  </div>
<% end %>