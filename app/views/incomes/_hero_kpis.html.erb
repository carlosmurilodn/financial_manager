<div id="incomes-hero-kpis" class="app-incomes-hero-kpis">
  <%= link_to new_income_path,
              class: "app-expenses-hero-kpis__action",
              data: { turbo_frame: "modal" } do %>
    <span class="app-expenses-hero-kpis__action-icon">
      <span class="material-symbols-rounded">add</span>
    </span>
    <span class="app-expenses-hero-kpis__action-copy">
      <strong><%= t("buttons.new.feminine", model: t("models.income")) %></strong>
    </span>
  <% end %>

  <div class="stat-card stat-card--primary">
    <div class="stat-card__icon">
      <span class="material-symbols-rounded">history</span>
    </div>
    <div>
      <span class="stat-card__label">Saldo do Mês Anterior</span>
      <strong class="stat-card__value">
        <%= number_to_currency(@previous_balance || 0, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
      </strong>
    </div>
  </div>

  <div class="stat-card stat-card--success">
    <div class="stat-card__icon">
      <span class="material-symbols-rounded">trending_up</span>
    </div>
    <div>
      <span class="stat-card__label">Total Recebido</span>
      <strong class="stat-card__value">
        <%= number_to_currency(@total_received || 0, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
      </strong>
    </div>
  </div>

  <div class="stat-card stat-card--warning">
    <div class="stat-card__icon">
      <span class="material-symbols-rounded">pending_actions</span>
    </div>
    <div>
      <span class="stat-card__label">Total Pendente</span>
      <strong class="stat-card__value">
        <%= number_to_currency(@total_pending || 0, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
      </strong>
    </div>
  </div>

  <div class="stat-card stat-card--danger">
    <div class="stat-card__icon">
      <span class="material-symbols-rounded">account_balance_wallet</span>
    </div>
    <div>
      <span class="stat-card__label">Saldo Atual</span>
      <strong class="stat-card__value">
        <%= number_to_currency(@current_balance || 0, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
      </strong>
    </div>
  </div>
</div>
