<!DOCTYPE html>
<html>
  <head>
    <title>Gerenciador Financeiro💲</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag "/icon.svg", type: "image/svg+xml" %>
    <%= favicon_link_tag "/icon.png", type: "image/png" %>
    <link rel="manifest" href="<%= pwa_manifest_path(format: :json) %>">
    <meta name="theme-color" content="#0f766e">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet">
    <script>
      const themeMedia = window.matchMedia("(prefers-color-scheme: dark)");
      const mobileMedia = window.matchMedia("(max-width: 991px)");
      const savedPreference = localStorage.getItem("app-theme-preference");
      const legacyTheme = localStorage.getItem("app-theme");
      const validPreferences = ["system", "fincan", "night"];
      const themePreference = validPreferences.includes(savedPreference)
        ? savedPreference
        : mobileMedia.matches
          ? "system"
          : ["fincan", "night"].includes(legacyTheme)
            ? legacyTheme
            : "fincan";
      const activeTheme = themePreference === "system"
        ? themeMedia.matches ? "night" : "fincan"
        : themePreference;
      document.documentElement.dataset.theme = activeTheme;
      localStorage.setItem("app-theme-preference", themePreference);
      localStorage.setItem("app-theme", activeTheme);
    </script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <%= render "shared/calculator_modal" %>

  <body>
    <div id="wrapper" class="app-shell">
      <%= render "shared/sidebar" %>

      <main id="page-content-wrapper" class="app-content">
        <div class="app-content__inner">
          <% if flash.any? %>
            <div class="app-flash-stack">
              <% flash.each do |key, msg| %>
                <div class="alert alert-<%= key == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show app-flash" role="alert">
                  <span class="material-symbols-rounded app-flash__icon"><%= key == "notice" ? "check_circle" : "error" %></span>
                  <span><%= msg %></span>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% end %>
            </div>
          <% end %>

          <%= yield %>

          <footer class="app-footer">
            <div class="app-footer__brand">
              <span class="material-symbols-rounded app-footer__icon">finance_mode</span>
              <div>
                <strong>Dashboard Financeiro</strong>
                <small>Controle receitas, despesas e previsoes em um unico painel.</small>
              </div>
            </div>

            <div class="app-footer__meta">
              <span class="app-footer__chip">Agenda Mensal</span>
              <span class="app-footer__chip">Planejamento Anual</span>
              <span class="app-footer__chip">Visao Consolidada</span>
            </div>

            <div class="app-footer__credit">
              <small>Desenvolvido por</small>
              <strong>Carlos Murilo Duarte Novais</strong>
              <span><%= Date.current.year %></span>
            </div>
          </footer>
        </div>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  </body>
</html>
