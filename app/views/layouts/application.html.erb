<!DOCTYPE html>
<html>
  <head>
    <title>Gerenciador Financeiro💲</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- CSS do Rails -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" %>


    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
  </head>

  <%= render "shared/calculator_modal" %>

  <body style="background-color: #e2e2e2ff;">
    <div id="wrapper" class="d-flex">
    <!-- Sidebar Lateral -->
    <%= render "shared/sidebar" %>

      <!-- Page content -->
      <div id="page-content-wrapper" class="flex-fill ms-sidebar">
        <div class="container-fluid py-4">
          <% if flash.any? %>
            <% flash.each do |key, msg| %>
              <div class="alert alert-<%= key == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
                <%= msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% end %>
          <% end %>

          <%= yield %>
          
        </div>
      </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <style>
      #page-content-wrapper {
        flex: 1;
        transition: margin-left 0.3s ease;
        margin-left: 250px;
      }

      #wrapper.collapsed #sidebar-wrapper {
        width: 60px;
      }

      #wrapper.collapsed #page-content-wrapper {
        margin-left: 60px;
      }
    </style>
  </body>
</html>
