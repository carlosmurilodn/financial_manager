<section class="app-page">
  <div class="app-page__hero">
    <div class="app-page__hero-copy">
      <span class="app-page__hero-icon">
        <span class="material-symbols-rounded">insert_chart</span>
      </span>
      <div>
        <p class="app-page__eyebrow">Análises</p>
        <h1 class="app-page__title">Relatórios</h1>
        <%# <p class="app-page__description">Acesse visões analíticas e relatórios estratégicos para acompanhar sua operação financeira.</p> %>
      </div>
    </div>
  </div>

  <div class="app-reports-grid">
    <%= link_to forecast_reports_path, class: "app-report-card text-decoration-none" do %>
      <span class="app-report-card__icon material-symbols-rounded">query_stats</span>
      <strong>Previsão Financeira</strong>
      <small>Projeção anual para acompanhar saldo, receitas e despesas.</small>
    <% end %>

    <%= link_to report_expenses_path, class: "app-report-card text-decoration-none" do %>
      <span class="app-report-card__icon material-symbols-rounded">receipt_long</span>
      <strong>Relatório de Despesas</strong>
      <small>Consulta detalhada com filtros e exportação em PDF.</small>
    <% end %>
  </div>
</section>
