<!-- 🔢 CALCULADORA (MODAL INLINE) -->
<div id="calculator-modal" class="modal-overlay">
  <div class="modal-content">
    <div class="modal-header">
      <h5>Calculadora</h5>
      <button class="close-modal">&times;</button>
    </div>
    <div class="modal-body" style="display:flex; flex-direction:column; height:450px;">
      <!-- display + histórico -->
      <div id="calc-display-container">
        <div id="calc-history"></div>
        <input type="text" id="calc-display" readonly>
        <div id="calc-temp"></div>
      </div>

      <!-- teclado fixo -->
      <div id="calc-buttons">
        <button>(</button><button>)</button><button id="clear">C</button><button>/</button>
        <button>7</button><button>8</button><button>9</button><button>*</button>
        <button>4</button><button>5</button><button>6</button><button>-</button>
        <button>1</button><button>2</button><button>3</button><button>+</button>
        <button>0</button><button>.</button><button>=</button>
      </div>
    </div>
  </div>
</div>

<style>
/* --- Modal --- */
.modal-overlay {
  display:none; position:fixed; inset:0;
  background-color:rgba(0,0,0,0.6);
  justify-content:center; align-items:center; z-index:2000;
}
.modal-content {
  background:#fff; padding:20px; border-radius:12px; width:320px;
  box-shadow:0 4px 10px rgba(0,0,0,0.3); animation:fadeIn 0.3s ease;
}
.modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.modal-header h5 { margin:0; font-weight:bold; }
.close-modal { border:none; background:none; font-size:1.5rem; cursor:pointer; }

/* --- Display + Histórico --- */
#calc-display-container {
  flex-grow:1;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  overflow:hidden;
  margin-bottom:10px;
  border: 1px solid #ccc;
  border-radius:6px;
  padding:8px;
  background-color:#f8f8f8;
}
#calc-history {
  font-size:0.85rem;
  color:#555;
  max-height:100px;
  overflow-y:auto;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  margin-bottom:4px;
}
#calc-display {
  width:100%;
  font-size:1.4rem;
  text-align:right;
  border:none;
  background:transparent;
  outline:none;
  color:#000;
}
#calc-temp {
  text-align:right;
  font-size:1.1rem;
  color:#888;
  margin-top:2px;
}

/* --- Botões --- */
#calc-buttons {
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:8px;
}
#calc-buttons button {
  padding:10px;
  font-size:1rem;
  border:none;
  border-radius:8px;
  background:#e8e8e8;
  cursor:pointer;
  transition:0.2s;
}
#calc-buttons button:hover { background:#d0d0d0; }

/* --- Resultado --- */
.positive { color: green; }
.negative { color: blue; }

@keyframes fadeIn { from {opacity:0; transform:scale(0.9);} to {opacity:1; transform:scale(1);} }
</style>

<script>
document.addEventListener("turbo:load", () => {
  // --- ELEMENTOS PRINCIPAIS ---
  const modal = document.getElementById("calculator-modal");
  const openBtn = document.getElementById("link-calculator");
  if(!modal || !openBtn) return;

  const closeBtn = modal.querySelector(".close-modal");
  const display = document.getElementById("calc-display");
  const tempDisplay = document.getElementById("calc-temp");
  const historyDiv = document.getElementById("calc-history");
  const buttons = document.querySelectorAll("#calc-buttons button");

  // Histórico das operações (máx 5)
  let history = [];

  // --- ABRIR MODAL ---
  openBtn.addEventListener("click", (e) => {
    e.preventDefault();
    display.value = "";
    tempDisplay.textContent = "";
    history = [];
    historyDiv.innerHTML = "";
    modal.style.display = "flex";
  });

  // --- FECHAR MODAL ---
  closeBtn.addEventListener("click", () => modal.style.display = "none");
  window.addEventListener("click", (event) => { if(event.target === modal) modal.style.display = "none"; });

  // --- FUNÇÃO PARA ATUALIZAR O HISTÓRICO ---
  function updateHistory() {
    historyDiv.innerHTML = history.map(item => {
      const color = item.result >= 0 ? "positive" : "negative";
      return `<div><strong>${item.expr}</strong> = <span class="${color}">${item.result}</span></div>`;
    }).join("");
    historyDiv.scrollTop = historyDiv.scrollHeight;
  }

  // --- FUNÇÃO PARA AVALIAR EXPRESSÃO COM SEGURANÇA ---
  function safeEval(expr) {
    try { return eval(expr.replace(/[^-()\d/*+.]/g,"")) || 0; }
    catch { return null; }
  }

  // --- FUNÇÃO PARA ATUALIZAR RESULTADO TEMPORÁRIO ---
  function updateTempResult() {
    const val = display.value;
    const result = safeEval(val);
    tempDisplay.textContent = (result !== null && val) ? `= ${result}` : "";
  }

  // --- FUNÇÃO PRINCIPAL DE ENTRADA ---
  function handleInput(val) {
    const lastChar = display.value.slice(-1);

    if(val === "C") { display.value = ""; tempDisplay.textContent = ""; return; }

    if(val === "=") {
      const result = safeEval(display.value);
      if(result !== null) {
        history.push({ expr: display.value, result });
        if(history.length > 5) history.shift();
        updateHistory();
        display.value = result;
        tempDisplay.textContent = "";
      }
      return;
    }

    // substitui sinais duplicados
    if(/[+\-*/.]/.test(val) && /[+\-*/.]$/.test(display.value)) {
      display.value = display.value.slice(0,-1) + val;
    } else {
      display.value += val;
    }

    updateTempResult();
  }

  // --- CLIQUE NOS BOTÕES ---
  buttons.forEach(btn => btn.addEventListener("click", () => handleInput(btn.textContent)));

  // --- TECLADO ---
  document.addEventListener("keydown", (e) => {
    if(modal.style.display !== "flex") return;

    if(e.key === "Enter") { e.preventDefault(); handleInput("="); }
    else if(e.key === "Escape") { modal.style.display = "none"; }
    else if(e.key === "Backspace") { display.value = display.value.slice(0,-1); updateTempResult(); }
    else if(/[0-9+\-*/().]/.test(e.key)) { handleInput(e.key); }
  });
});
</script>
