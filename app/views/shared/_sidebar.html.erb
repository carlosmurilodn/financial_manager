<aside id="sidebar-wrapper" class="app-sidebar">
  <div class="app-sidebar__inner">
    <div class="app-sidebar__brand">
      <div class="app-sidebar__logo" aria-hidden="true">
        <span class="material-symbols-rounded">account_balance_wallet</span>
      </div>
      <div class="app-sidebar__brand-copy">
        <span class="sidebar-title">Dashboard Financeiro</span>
        <small>Visao geral do sistema</small>
      </div>
      <button id="sidebarToggle" class="app-sidebar__toggle" type="button" aria-label="Alternar menu">
        <span class="material-symbols-rounded">menu</span>
      </button>
    </div>

    <nav class="app-sidebar__nav">
      <%= link_to root_path, class: "app-nav-link #{'active-menu' if current_page?(root_path)}", id: "link-home", data: { turbo: false } do %>
        <span class="material-symbols-rounded app-nav-link__icon">space_dashboard</span>
        <span class="link-text">Dashboard</span>
      <% end %>

      <%= link_to expenses_path, class: "app-nav-link #{'active-menu' if current_page?(expenses_path)}", id: "link-expenses", data: { turbo: false } do %>
        <span class="material-symbols-rounded app-nav-link__icon">receipt_long</span>
        <span class="link-text">Despesas</span>
      <% end %>

      <%= link_to incomes_path, class: "app-nav-link #{'active-menu' if current_page?(incomes_path)}", id: "link-incomes", data: { turbo: false } do %>
        <span class="material-symbols-rounded app-nav-link__icon">payments</span>
        <span class="link-text">Receitas</span>
      <% end %>

      <%= link_to categories_path, class: "app-nav-link #{'active-menu' if current_page?(categories_path)}", id: "link-categories", data: { turbo: false } do %>
        <span class="material-symbols-rounded app-nav-link__icon">category</span>
        <span class="link-text">Categorias</span>
      <% end %>

      <%= link_to cards_path, class: "app-nav-link #{'active-menu' if current_page?(cards_path)}", id: "link-cards", data: { turbo: false } do %>
        <span class="material-symbols-rounded app-nav-link__icon">credit_card</span>
        <span class="link-text">Cartoes</span>
      <% end %>

      <%= link_to "#", class: "app-nav-link", id: "link-calculator" do %>
        <span class="material-symbols-rounded app-nav-link__icon">calculate</span>
        <span class="link-text">Calculadora</span>
      <% end %>

      <%= link_to reports_path, class: "app-nav-link #{'active-menu' if current_page?(reports_path)}", id: "link-reports", data: { turbo: false } do %>
        <span class="material-symbols-rounded app-nav-link__icon">insert_chart</span>
        <span class="link-text">Relatorios</span>
      <% end %>
    </nav>

    <div class="app-sidebar__footer">
      <div class="app-sidebar__utilities">
        <button id="themeToggle" class="app-theme-toggle" type="button" aria-label="Alternar tema">
          <span class="material-symbols-rounded app-theme-toggle__icon">palette</span>
          <span class="app-theme-toggle__copy">
            <strong class="link-text app-theme-toggle__label">Tema atual</strong>
            <small class="link-text app-theme-toggle__meta">Trocar tema</small>
          </span>
        </button>
      </div>

      <%# <section class="app-sidebar__weather">
        <div class="app-sidebar__weather-header">
          <span>Goiania</span>
        </div>
        <div id="current-time" class="app-sidebar__time"></div>
        <div id="weather-info"></div>
      </section> %>
    </div>
  </div>
</aside>

<script>
  const APP_THEMES = [
    { id: "fincan", label: "Fincan Blue", nextLabel: "Noite Roxa", icon: "finance_mode" },
    { id: "night", label: "Noite Roxa", nextLabel: "Fincan Blue", icon: "dark_mode" }
  ];

  function updateClock() {
    const now = new Date();
    const hours = String(now.getHours()).padStart(2, "0");
    const minutes = String(now.getMinutes()).padStart(2, "0");
    const seconds = String(now.getSeconds()).padStart(2, "0");
    const timeMarkup = `<span class="app-sidebar__time-main">${hours}:${minutes}</span><span class="app-sidebar__time-seconds">:${seconds}</span>`;

    ["current-time", "dashboard-current-time"].forEach((id) => {
      const timeNode = document.getElementById(id);
      if (timeNode) timeNode.innerHTML = timeMarkup;
    });
  }

  async function loadWeather() {
    const weatherNodes = ["weather-info", "dashboard-weather-info"]
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    if (!weatherNodes.length) return;

    const apiKey = "d56b203c35ee12ffb7de5bf2aaf5eccd";
    const city = "Goiânia,BR";
    const url = `https://api.openweathermap.org/data/2.5/forecast?q=${encodeURIComponent(city)}&units=metric&lang=pt_br&appid=${apiKey}`;

    try {
      const res = await fetch(url);
      const data = await res.json();
      if (!data.list) throw new Error("Sem dados");

      const todayForecasts = data.list.slice(0, 8);
      const tempNow = data.list[0].main.temp.toFixed(0);
      const tempMin = Math.min(...todayForecasts.map((forecast) => forecast.main.temp_min)).toFixed(0);
      const tempMax = Math.max(...todayForecasts.map((forecast) => forecast.main.temp_max)).toFixed(0);
      const todayIcon = data.list[0].weather[0].icon;
      const todayDesc = data.list[0].weather[0].description;
      const todayWeatherId = data.list[0].weather[0].id;

      const dashboardWeatherClass = (() => {
        const isNight = todayIcon.endsWith("n");

        if (todayWeatherId >= 200 && todayWeatherId < 300) return "today-weather--storm";
        if (todayWeatherId >= 300 && todayWeatherId < 400) return isNight ? "today-weather--drizzle-night" : "today-weather--drizzle";
        if (todayWeatherId >= 500 && todayWeatherId < 600) return isNight ? "today-weather--rain-night" : "today-weather--rain";
        if (todayWeatherId >= 600 && todayWeatherId < 700) return "today-weather--snow";
        if (todayWeatherId >= 700 && todayWeatherId < 800) return "today-weather--mist";
        if (todayWeatherId === 800) return isNight ? "today-weather--clear-night" : "today-weather--clear";
        if (todayWeatherId > 800) return isNight ? "today-weather--cloudy-night" : "today-weather--clouds";

        return isNight ? "today-weather--clear-night" : "today-weather--clear";
      })();

      const sidebarWeatherMarkup = `
        <div class="today-weather">
          <div class="today-weather__current">
            <img src="https://openweathermap.org/img/wn/${todayIcon}@2x.png" alt="${todayDesc}" width="34" height="34">
            <strong>${tempNow}°C</strong>
          </div>
          <div class="today-weather__details">
            <span class="text-capitalize">${todayDesc}</span>
            <small>Min ${tempMin}°C · Max ${tempMax}°C</small>
          </div>
        </div>
      `;

      const dashboardWeatherMarkup = `
        <div class="today-weather today-weather--dashboard ${dashboardWeatherClass}">
          <div class="today-weather__current">
            <img src="https://openweathermap.org/img/wn/${todayIcon}@2x.png" alt="${todayDesc}" width="68" height="68">
            <div class="today-weather__current-copy">
              <strong>${tempNow}°C</strong>
              <span class="today-weather__city">Goiania</span>
            </div>
          </div>
          <div class="today-weather__details">
            <span class="text-capitalize">${todayDesc}</span>
            <small>Min ${tempMin}°C · Max ${tempMax}°C</small>
          </div>
        </div>
      `;

      const sidebarNode = document.getElementById("weather-info");
      const dashboardNode = document.getElementById("dashboard-weather-info");

      if (sidebarNode) sidebarNode.innerHTML = sidebarWeatherMarkup;
      if (dashboardNode) dashboardNode.innerHTML = dashboardWeatherMarkup;
    } catch (error) {
      weatherNodes.forEach((node) => {
        node.textContent = "Clima indisponivel";
      });
    }
  }

  function updateSidebar() {
    const wrapper = document.getElementById("wrapper");
    const sidebar = document.getElementById("sidebar-wrapper");
    if (!wrapper || !sidebar) return;

    const title = sidebar.querySelector(".app-sidebar__brand-copy");
    const linkTexts = sidebar.querySelectorAll(".link-text");
    const collapsed = localStorage.getItem("sidebar-collapsed") === "true";

    wrapper.classList.toggle("collapsed", collapsed);
    linkTexts.forEach((element) => {
      element.style.display = collapsed ? "none" : "inline";
    });

    if (title) title.style.display = collapsed ? "none" : "flex";
  }

  function getCurrentTheme() {
    const savedTheme = localStorage.getItem("app-theme");
    return APP_THEMES.some((theme) => theme.id === savedTheme) ? savedTheme : "fincan";
  }

  function applyTheme(themeId) {
    document.documentElement.dataset.theme = themeId;
    localStorage.setItem("app-theme", themeId);
    updateThemeToggle();
  }

  function updateThemeToggle() {
    const toggle = document.getElementById("themeToggle");
    if (!toggle) return;

    const currentTheme = APP_THEMES.find((theme) => theme.id === getCurrentTheme()) || APP_THEMES[0];
    const nextTheme = APP_THEMES[(APP_THEMES.findIndex((theme) => theme.id === currentTheme.id) + 1) % APP_THEMES.length];

    const icon = toggle.querySelector(".app-theme-toggle__icon");
    const label = toggle.querySelector(".app-theme-toggle__label");
    const meta = toggle.querySelector(".app-theme-toggle__meta");

    if (icon) icon.textContent = currentTheme.icon;
    if (label) label.textContent = currentTheme.label;
    if (meta) meta.textContent = `Trocar para ${nextTheme.label}`;

    toggle.setAttribute("title", `Tema atual: ${currentTheme.label}. Clique para alternar.`);
    toggle.setAttribute("aria-label", `Tema atual: ${currentTheme.label}. Clique para alternar para ${nextTheme.label}.`);
  }

  document.addEventListener("turbo:load", () => {
    updateClock();
    updateSidebar();
    updateThemeToggle();
    loadWeather();

    const toggleButton = document.getElementById("sidebarToggle");
    if (!toggleButton || toggleButton.dataset.bound === "true") return;

    toggleButton.dataset.bound = "true";
    toggleButton.addEventListener("click", () => {
      const wrapper = document.getElementById("wrapper");
      if (!wrapper) return;

      wrapper.classList.toggle("collapsed");
      localStorage.setItem("sidebar-collapsed", wrapper.classList.contains("collapsed"));
      updateSidebar();
    });

    const themeToggle = document.getElementById("themeToggle");
    if (themeToggle && themeToggle.dataset.bound !== "true") {
      themeToggle.dataset.bound = "true";
      themeToggle.addEventListener("click", () => {
        const currentTheme = getCurrentTheme();
        const currentIndex = APP_THEMES.findIndex((theme) => theme.id === currentTheme);
        const nextTheme = APP_THEMES[(currentIndex + 1) % APP_THEMES.length];
        applyTheme(nextTheme.id);
      });
    }
  });

  setInterval(updateClock, 1000);
</script>
