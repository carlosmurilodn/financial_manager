<div id="sidebar-wrapper" class="d-flex flex-column align-items-start text-white position-fixed vh-100">
  <div class="sidebar-header d-flex align-items-center justify-content-between w-100 px-3 py-2">
    <span class="fw-bold sidebar-title text-center">Gerenciador Financeiro 💲</span>
    <button id="sidebarToggle" class="btn btn-sm text-black" style="background-color: transparent; font-size: 1.2rem;">☰</button>
  </div>

  <!-- Links -->
  <div class="list-group list-group-flush w-100 mt-2">
    <%= link_to root_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(root_path)} text-white", id: "link-home", data: { turbo: false } do %>
      <%= image_tag "icons/home.png", alt: "Home", class: "icon me-2", size: "24x24" %>
      <span class="link-text">Home</span>
    <% end %>

    <%= link_to expenses_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(expenses_path)} text-white", id: "link-expenses", data: { turbo: false } do %>
      <%= image_tag "icons/expense.png", alt: "Despesas", class: "icon me-2", size: "24x24" %>
      <span class="link-text">Despesas</span>
    <% end %>

    <%= link_to incomes_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(incomes_path)} text-white", id: "link-incomes", data: { turbo: false } do %>
      <%= image_tag "icons/income.png", alt: "Receitas", class: "icon me-2", size: "24x24" %>
      <span class="link-text">Receitas</span>
    <% end %>

    <%= link_to categories_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(categories_path)} text-white", id: "link-categories", data: { turbo: false } do %>
      <%= image_tag "icons/category.png", alt: "Categorias", class: "icon me-2", size: "24x24" %>
      <span class="link-text">Categorias</span>
    <% end %>

    <%= link_to cards_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(cards_path)} text-white", id: "link-cards", data: { turbo: false } do %>
      <%= image_tag "icons/card.png", alt: "Cartões", class: "icon me-2", size: "24x24" %>
      <span class="link-text">Cartões</span>
    <% end %>

    <%= link_to "#", class: "list-group-item list-group-item-action d-flex align-items-center text-white", id: "link-calculator" do %>
      <%= image_tag "icons/calculator.png", alt: "Calculadora", class: "icon me-2", size: "24x24" %>
      <span class="link-text">Calculadora</span>
    <% end %>

    
  </div>

  <!-- Relógio e Clima -->
  <div class="w-100 px-3 py-2 mt-2 text-center border-bottom border-top border-secondary">
    <div id="current-time" class="fs-6 fw-semibold"></div>
    <div id="weather-info" class=""></div>
  </div>
</div>


<!-- CSS -->
<style>
  /* --- Modal da Calculadora --- */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background-color: rgba(0,0,0,0.6);
    justify-content: center;
    align-items: center;
    z-index: 2000;
  }

  .modal-content {
    background-color: #ffffff;
    padding: 20px;
    border-radius: 12px;
    width: 300px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    animation: fadeIn 0.3s ease;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .modal-header h5 {
    margin: 0;
    font-weight: bold;
  }

  .close-modal {
    border: none;
    background: none;
    font-size: 1.5rem;
    cursor: pointer;
  }

  .modal-body {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #calc-display {
    width: 100%;
    padding: 8px;
    font-size: 1.2rem;
    text-align: right;
    margin-bottom: 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
  }

  #calc-buttons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    width: 100%;
  }

  #calc-buttons button {
    padding: 10px;
    font-size: 1rem;
    cursor: pointer;
    border: none;
    border-radius: 8px;
    background-color: #e8e8e8;
    transition: background-color 0.2s ease;
  }

  #calc-buttons button:hover {
    background-color: #d0d0d0;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

</style>

<!-- JS -->
<script>
  document.addEventListener("turbo:load", () => {
    const modal = document.getElementById("calculator-modal");
    const openBtn = document.getElementById("link-calculator");
    if (!modal || !openBtn) return;

    const closeBtn = modal.querySelector(".close-modal");
    const display = document.getElementById("calc-display");
    const buttons = document.querySelectorAll("#calc-buttons button");

    // --- abrir modal ---
    openBtn.addEventListener("click", (e) => {
      e.preventDefault();
      display.value = ""; // abre sempre limpa
      modal.style.display = "flex";
    });

    // --- fechar modal ---
    closeBtn.addEventListener("click", () => (modal.style.display = "none"));
    window.addEventListener("click", (event) => {
      if (event.target === modal) modal.style.display = "none";
    });

    // --- lógica da calculadora ---
    buttons.forEach(btn => {
      btn.addEventListener("click", () => {
        const val = btn.textContent;

        if (val === "C") {
          display.value = "";
        } else if (val === "=") {
          try {
            display.value = eval(display.value || "0");
          } catch {
            display.value = "Erro";
          }
        } else {
          display.value += val;
        }
      });
    });
  });

</script>
