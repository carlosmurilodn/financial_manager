<div id="sidebar-wrapper" class="d-flex flex-column align-items-start text-white position-fixed vh-100">
  <div class="sidebar-header d-flex align-items-center justify-content-between w-100 px-3 py-2">
    <span class="fs-5 fw-bold sidebar-title text-center">Gerenciador Financeiro</span>
    <button id="sidebarToggle" class="btn btn-sm text-black" style="background-color: transparent; font-size: 1.2rem;">☰</button>
  </div>

  <!-- Links -->
  <div class="list-group list-group-flush w-100 mt-2">
    <%= link_to root_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(root_path)} text-white", id: "link-home", data: { turbo: false } do %>
      <span class="icon me-2">🏠</span>
      <span class="link-text">Home</span>
    <% end %>

    <%= link_to expenses_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(expenses_path)} text-white", id: "link-expenses", data: { turbo: false } do %>
      <span class="icon me-2">💸</span>
      <span class="link-text">Despesas</span>
    <% end %>

    <%= link_to incomes_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(incomes_path)} text-white", id: "link-incomes", data: { turbo: false } do %>
      <span class="icon me-2">💰</span>
      <span class="link-text">Receitas</span>
    <% end %>

    <%= link_to categories_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(categories_path)} text-white", id: "link-categories", data: { turbo: false } do %>
      <span class="icon me-2">🗂️</span>
      <span class="link-text">Categorias</span>
    <% end %>

    <%= link_to cards_path, class: "list-group-item list-group-item-action d-flex align-items-center #{'active-menu' if current_page?(cards_path)} text-white", id: "link-cards", data: { turbo: false } do %>
      <span class="icon me-2">💳</span>
      <span class="link-text">Cartões</span>
    <% end %>
  </div>

  <!-- Relógio e Clima -->
  <div class="w-100 px-3 py-2 mt-2 text-center border-bottom border-top border-secondary">
    <div id="current-time" class="fs-6 fw-semibold"></div>
    <div id="weather-info" class="ms-1"></div>
  </div>

</div>

<!-- CSS -->
<style>
  #sidebar-wrapper {
    width: 250px;
    transition: width 0.3s ease;
    z-index: 1000;
    background-color: #343a40;
  }

  #wrapper.collapsed #sidebar-wrapper {
    min-width: 60px;
  }

  .list-group-item {
    background-color: transparent;
    border: none;
    color: white;
    transition: all 0.3s ease;
    width: 100%;
    box-sizing: border-box;
    padding: 0.75rem 1rem;
    border-radius: 5px;
  }

  .list-group-item:hover {
    background-color: rgba(103, 176, 236, 0.55) !important;
    border-radius: 5px;
    width: calc(100% - 20px);
    margin-left: 10px;
    margin-right: 10px;
  }

  .list-group-item.active-menu {
    background-color: rgba(103, 176, 236, 1) !important;
    color: white !important;
    border-radius: 5px;
    width: calc(100% - 20px);
    margin-left: 10px;
    margin-right: 10px;
  }

  #current-time {
    font-size: 0.95rem;
  }

  #weather-info {
    font-size: 0.8rem;
    line-height: 1.3;
  }

  #weather-info img {
    vertical-align: middle;
  }

  .icon { display: inline-block; }
  .link-text { transition: opacity 0.3s ease; }
  .sidebar-header { width: 100%; }
  #sidebarToggle { cursor: pointer; }

  .today-weather {
    font-size: 1rem; /* ou 1.1rem, 1.2rem, conforme quiser */
    font-weight: 600;
  }

  .today-weather span {
    font-size: 1.1rem;
  }

  .today-weather img {
    width: 50px !important;
  }


  
</style>

<!-- JS -->
<script>
  // --- Atualiza hora em tempo real ---
  function updateClock() {
    const now = new Date();
    const timeStr = now.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    document.getElementById("current-time").textContent = timeStr;
  }
  setInterval(updateClock, 1000);
  updateClock();

  // --- Clima com ícone + min/max ---
  async function loadWeather() {
    const apiKey = "d56b203c35ee12ffb7de5bf2aaf5eccd"; // 🔑 substitua pela sua chave do OpenWeatherMap
    const city = "Goiânia,BR"; // altere se quiser
    const url = `https://api.openweathermap.org/data/2.5/forecast?q=${encodeURIComponent(city)}&units=metric&lang=pt_br&appid=${apiKey}`;

    try {
      const res = await fetch(url);
      const data = await res.json();
      if (!data.list) throw new Error("Sem dados");

      // Hoje (média do dia)
      const todayForecasts = data.list.slice(0, 8);
      const temps = todayForecasts.map(f => f.main.temp);
      const tempMin = Math.min(...todayForecasts.map(f => f.main.temp_min)).toFixed(0);
      const tempMax = Math.max(...todayForecasts.map(f => f.main.temp_max)).toFixed(0);
      const todayIcon = todayForecasts[0].weather[0].icon;
      const todayDesc = todayForecasts[0].weather[0].description.toUpperCase();

      let html = `
        <div class="today-weather d-flex align-items-center justify-content-center flex-column">
          <div class= " d-flex align-items-center justify-content-center flex-row">
          <img src="https://openweathermap.org/img/wn/${todayIcon}.png" alt="${todayDesc}" width="50">
          <span class="ms-1">${tempMin}°C / ${tempMax}°C</span>
          </div>
          <span class="ms-1 mb-2">${todayDesc}</span>
        </div>
      `;

      // Próximos 3 dias
      html += '<div class="mt-1">';
      for (let i = 8; i <= 32; i += 8) {
        const forecast = data.list[i];
        if (!forecast) continue;
        const day = new Date(forecast.dt_txt).toLocaleDateString('pt-BR', { weekday: 'short' });
        const tMin = forecast.main.temp_min.toFixed(0);
        const tMax = forecast.main.temp_max.toFixed(0);
        const icon = forecast.weather[0].icon;
        const desc = forecast.weather[0].description;
        html += `
          <div class="d-flex align-items-center justify-content-start">
            <span class="ms-1">${day}:</span>
            <img src="https://openweathermap.org/img/wn/${icon}.png" alt="" width="20">
            <span class="ms-1">${tMin}°C / ${tMax}°C</span>
          </div>
        `;
      }
      html += '</div>';

      document.getElementById("weather-info").innerHTML = html;
    } catch (err) {
      document.getElementById("weather-info").textContent = "Clima indisponível";
    }
  }

  // --- Sidebar collapsible ---
  function updateSidebar() {
    const wrapper = document.getElementById("wrapper");
    const sidebar = document.getElementById("sidebar-wrapper");
    const title = sidebar.querySelector(".sidebar-title");
    const linkTexts = sidebar.querySelectorAll(".link-text");
    const collapsed = localStorage.getItem("sidebar-collapsed") === "true";

    if (collapsed) wrapper.classList.add("collapsed");
    else wrapper.classList.remove("collapsed");

    linkTexts.forEach(el => el.style.display = collapsed ? "none" : "inline");
    title.style.display = collapsed ? "none" : "inline";
  }

  document.addEventListener("turbo:load", () => {
    updateSidebar();
    loadWeather();

    const toggleButton = document.getElementById("sidebarToggle");
    toggleButton.addEventListener("click", () => {
      const wrapper = document.getElementById("wrapper");
      wrapper.classList.toggle("collapsed");
      localStorage.setItem("sidebar-collapsed", wrapper.classList.contains("collapsed"));
      updateSidebar();
    });
  });
</script>
