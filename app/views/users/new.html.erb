<section class="app-page-hero">
  <div>
    <span class="app-page-hero__eyebrow">Primeiro acesso</span>
    <h1>Criar conta</h1>
    <p>Cadastre uma senha para proteger o gerenciador financeiro. Depois voce podera ativar entrada por biometria.</p>
  </div>
</section>

<section class="dashboard-grid">
  <article class="dashboard-card dashboard-card--mint">
    <div class="dashboard-card__header">
      <div>
        <h2 class="dashboard-card__title">Conta principal</h2>
        <p class="text-muted mb-0">Use uma senha com pelo menos 8 caracteres.</p>
      </div>
      <span class="material-symbols-rounded">lock</span>
    </div>

    <div class="dashboard-card__body">
      <%= form_with model: @user, url: users_path, data: { turbo: false }, class: "d-grid gap-3" do |form| %>
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <%= @user.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div>
          <%= form.label :email, "E-mail", class: "form-label" %>
          <%= form.email_field :email, class: "form-control", autocomplete: "email", required: true %>
        </div>

        <div>
          <%= form.label :password, "Senha", class: "form-label" %>
          <%= form.password_field :password, class: "form-control", autocomplete: "new-password", required: true %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirmar senha", class: "form-label" %>
          <%= form.password_field :password_confirmation, class: "form-control", autocomplete: "new-password", required: true %>
        </div>

        <button type="submit" class="btn btn-primary">Criar conta</button>
      <% end %>
    </div>
  </article>
</section>
